---
// src/layouts/Layout.astro
import '../styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import SeoHead from '@/components/SeoHead.astro';
import { getTranslations, t } from '@/lib/i18n-server';

// Google AdSense — set PUBLIC_ADSENSE_CLIENT env var before deploying live
const ADSENSE_CLIENT = import.meta.env.PUBLIC_ADSENSE_CLIENT || '';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  /** Hide the header/footer chrome (used on /p policy view) */
  bare?: boolean;
  /** SEO schema type for JSON-LD */
  schemaType?: 'WebApplication' | 'FAQPage' | 'WebPage' | 'Article' | 'BreadcrumbList';
  /** Article-specific props for JSON-LD */
  article?: {
    publishedTime: string;
    modifiedTime?: string;
    author?: string;
    section?: string;
    tags?: string[];
  };
  /** Breadcrumb items for BreadcrumbList schema */
  breadcrumbs?: Array<{ name: string; url: string }>;
  /**
   * SEO page key for build-time i18n lookup.
   * When set, Layout loads the English translation JSON and resolves
   * seo.{pageKey}.title / seo.{pageKey}.description to render localized
   * <title> and <meta name="description"> tags.
   * Falls back to the explicit `title` / `description` props if the key
   * is not found in translations.
   */
  pageKey?: string;
}

const { title, description, canonical, ogType, noindex, bare = false, schemaType = 'WebApplication', article, breadcrumbs, pageKey } = Astro.props;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();

// Build-time i18n SEO lookup: resolve localized title/description from translation JSON
let seoTitle = title;
let seoDescription = description;
if (pageKey) {
  const tx = await getTranslations();
  const localizedTitle = t(tx, `seo.${pageKey}.title`);
  const localizedDesc = t(tx, `seo.${pageKey}.description`);
  // t() returns the key itself if not found — only use if it resolved
  if (localizedTitle !== `seo.${pageKey}.title`) seoTitle = localizedTitle;
  if (localizedDesc !== `seo.${pageKey}.description`) seoDescription = localizedDesc;
}
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <!-- Primary favicon: dark shield on light backgrounds. Multiple formats ensure cross-browser coverage. -->
    <link rel="icon" type="image/x-icon" href="/favicon_black.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#09090B" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {ADSENSE_CLIENT && (
      <script async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_CLIENT}`} crossorigin="anonymous" />
    )}
<link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" />
    </noscript>
    {/* FOUC prevention: set data-theme on <html> synchronously before paint.
        Priority: stored user choice > OS preference > dark fallback. */}
    <script is:inline>
      (function () {
        var theme = 'dark';
        try {
          var stored = localStorage.getItem('ppg-theme');
          var prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
          theme = stored === 'light' || stored === 'dark' ? stored : (prefersLight ? 'light' : 'dark');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
    <SeoHead title={seoTitle} description={seoDescription} canonical={canonical} ogType={ogType} noindex={noindex} schemaType={schemaType} article={article} breadcrumbs={breadcrumbs} />

    {/* React I18n — provides English translations for interactive components (Wizard, PolicyView, etc.). */}
  </head>
  <body class="min-h-screen flex flex-col antialiased bg-bg text-fg">
    <a href="#main-content" class="skip-link sr-only focus-visible:not-sr-only focus-visible:fixed focus-visible:left-4 focus-visible:top-4 focus-visible:z-[9999] focus-visible:rounded-button focus-visible:bg-bg focus-visible:px-4 focus-visible:py-2 focus-visible:text-sm focus-visible:font-medium focus-visible:text-fg focus-visible:shadow-dropdown focus-visible:outline-2 focus-visible:outline-ring focus-visible:outline-offset-2">
      Skip to content
    </a>
    {!bare && <Header />}
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    {!bare && <Footer />}
  </body>
</html>

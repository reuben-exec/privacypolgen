---
// src/components/sections/FAQ.astro
import faqData from '@/data/faq.json';
const faqs = faqData as { q: string; a: string }[];

export interface Props {
  schemaType?: string;
}
const { schemaType } = Astro.props;

// Build FAQPage JSON-LD if requested
const faqSchema = schemaType === 'FAQPage' ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.a,
    },
  })),
} : null;
---
{faqSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
)}
<section class="border-t border-border">
  <div class="mx-auto max-w-3xl px-6 py-20">
    <div class="text-center mb-12">
      <p class="text-xs uppercase tracking-widest text-fg-faint mb-2" data-i18n="faq.label">FAQ</p>
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight" data-i18n="faq.heading">Questions, answered.</h2>
    </div>
    <div class="rounded-card border border-border bg-bg-elevated divide-y divide-border overflow-hidden">
      {faqs.map((f, i) => (
        <details class="group px-6 py-4">
          <summary class="flex items-center justify-between gap-4 cursor-pointer list-none">
            <span class="text-sm font-medium" data-i18n={`faq.items.${i}.q`}>{f.q}</span>
            <svg class="h-4 w-4 text-fg-muted transition-transform group-open:rotate-45 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
          </summary>
          <p class="mt-3 text-sm text-fg-muted leading-relaxed" data-i18n={`faq.items.${i}.a`}>{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

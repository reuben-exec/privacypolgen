---
// src/components/sections/TrustBar.astro
import { getTranslations, t } from '@/lib/i18n-server';
interface Props { locale?: string }
const { locale = 'en' } = Astro.props;
const tx = await getTranslations(locale);
const services = [
  'Google Analytics', 'Plausible', 'Mixpanel',
  'Stripe', 'PayPal', 'Mailchimp',
  'ConvertKit', 'SendGrid', 'Cloudflare',
  'AWS', 'Google OAuth', 'Facebook Pixel',
];
---
<section class="border-t border-border">
  <div class="mx-auto max-w-6xl px-6 py-14">
    <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-3">
      {services.map((s) => (
        <span class="text-sm text-fg-muted/80 font-mono">{s}</span>
      ))}
      <span class="text-sm text-fg-faint font-mono italic">{t(tx, 'trustBar.more')}</span>
    </div>
  </div>
</section>

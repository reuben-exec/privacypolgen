---
// src/components/sections/FeatureGrid.astro
const features = [
  {
    title: 'Laws covered out of the box',
    body: 'GDPR, CCPA/CPRA, CalOPPA, COPPA, PIPEDA, LGPD, and PDPA-SG. Select the ones that apply to your business and we tailor the clauses accordingly.',
    icon: 'shield',
  },
  {
    title: 'Tailored to your stack',
    body: 'Pick from 25+ popular third-party services — Stripe, Google Analytics, Plausible, Mailchimp, SendGrid, and more — and we add the right contractual disclosures for each one automatically.',
    icon: 'puzzle',
  },
  {
    title: 'Shareable public URL',
    body: 'Every policy gets a unique shareable URL encoded entirely in your browser. Host it on your own domain, embed it in your site, or send the link to your lawyer for review.',
    icon: 'link',
  },
  {
    title: 'Export anywhere',
    body: 'Copy as Markdown, HTML, or plain text with one click. The Premium tier adds PDF and DOCX export for polished documentation.',
    icon: 'download',
  },
  {
    title: 'Real legal text, not Lorem Ipsum',
    body: 'Every clause is hand-written by legal professionals who reference the actual sections of GDPR, CCPA, COPPA, PIPEDA, LGPD, and DPDP Act they satisfy.',
    icon: 'file',
  },
  {
    title: 'Zero data, zero tracking',
    body: 'Your answers never leave your device. They\'re compressed and encoded into the URL itself using client-side DEFLATE. We don\'t run a backend, we don\'t log IPs, and we never see your policy content.',
    icon: 'lock',
  },
];

const iconPaths: Record<string, string> = {
  shield: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  puzzle: 'M19 11h-1V7a2 2 0 0 0-2-2h-4V4a2 2 0 1 0-4 0v1H4a2 2 0 0 0-2 2v4h1a2 2 0 1 1 0 4H2v4a2 2 0 0 0 2 2h4v-1a2 2 0 1 1 4 0v1h4a2 2 0 0 0 2-2v-4h1a2 2 0 1 0 0-4z',
  link: 'M10 13a5 5 0 0 0 7.07 0l3-3a5 5 0 0 0-7.07-7.07l-1.41 1.41M14 11a5 5 0 0 0-7.07 0l-3 3a5 5 0 0 0 7.07 7.07l1.41-1.41',
  download: 'M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3',
  file: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M16 13H8 M16 17H8 M10 9H8',
  lock: 'M19 11H5a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7a2 2 0 0 0-2-2z M7 11V7a5 5 0 0 1 10 0v4',
};

// Map icon names to de.json feature card keys
const iconToCardKey: Record<string, string> = {
  shield: 'laws',
  puzzle: 'stack',
  link: 'url',
  download: 'export',
  file: 'legal',
  lock: 'privacy',
};
---
<section class="border-t border-border">
  <div class="mx-auto max-w-6xl px-6 py-20">
    <div class="text-center mb-14">
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight" data-i18n="features.heading">Everything you need. Nothing you don't.</h2>
      <p class="mt-3 text-fg-muted max-w-2xl mx-auto" data-i18n="features.subtext">A privacy policy generator purpose-built for indie developers, SaaS founders, and small business owners who need a real, compliant policy without spending $500+ on a lawyer or struggling with generic one-size-fits-all templates.</p>
    </div>
    <div class="grid gap-px bg-border sm:grid-cols-2 lg:grid-cols-3 rounded-card overflow-hidden" data-stagger-group>
      {features.map((f, idx) => (
        <div class="stagger-item bg-bg-elevated p-7">
          <div class:list={["inline-flex h-9 w-9 items-center justify-center rounded-md mb-4", idx % 2 === 0 ? "bg-bg-card border border-border" : "bg-fg/[0.07]"]}>
            <svg class:list={["h-4.5 w-4.5", idx % 2 === 0 ? "text-fg-muted" : "text-fg"]} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d={iconPaths[f.icon]}></path>
            </svg>
          </div>
          <h3 class="text-base font-medium mb-1.5" data-i18n={`features.cards.${iconToCardKey[f.icon]}.title`}>{f.title}</h3>
          <p class="text-sm text-fg-muted leading-relaxed" data-i18n={`features.cards.${iconToCardKey[f.icon]}.body`}>{f.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
(function () {
  var group = document.querySelector('[data-stagger-group]')
  if (!group) return
  var items = group.querySelectorAll(':scope > .stagger-item')
  if (!items.length) return

  function showAll () {
    items.forEach(function (el) {
      el.classList.remove('is-hidden')
      el.classList.add('is-visible')
    })
  }

  function hideAll () {
    items.forEach(function (el) {
      el.classList.remove('is-visible')
      el.classList.add('is-hidden')
    })
  }

  var rect = group.getBoundingClientRect()
  if (rect.top < window.innerHeight && rect.bottom > 0) {
    showAll()
    return
  }

  hideAll()
  var observer = new IntersectionObserver(
    function (entries) {
      if (entries[0].isIntersecting) {
        showAll()
        observer.disconnect()
      }
    },
    { threshold: 0.1 }
  )
  observer.observe(group)
})()
</script>

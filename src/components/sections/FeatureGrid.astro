---
// src/components/sections/FeatureGrid.astro
const features = [
  {
    title: 'Laws covered out of the box',
    body: 'GDPR, CCPA/CPRA, CalOPPA, COPPA, PIPEDA, LGPD, and PDPA-SG. Select the ones that apply to your business.',
    icon: 'shield',
  },
  {
    title: 'Tailored to your stack',
    body: 'Pick from 25+ popular third-party services (Stripe, Google Analytics, Plausible, Mailchimp…) and we add the right disclosures automatically.',
    icon: 'puzzle',
  },
  {
    title: 'Shareable public URL',
    body: 'Every policy gets a unique shareable URL. Host it on your domain or send it to your lawyer for review.',
    icon: 'link',
  },
  {
    title: 'Export anywhere',
    body: 'Copy as Markdown, HTML, or plain text. Premium adds PDF and DOCX export.',
    icon: 'download',
  },
  {
    title: 'Real legal text, not Lorem Ipsum',
    body: 'Hand-written clauses that reference the actual sections of GDPR, CCPA, and COPPA they satisfy.',
    icon: 'file',
  },
  {
    title: 'Zero data, zero tracking',
    body: 'Your answers are encoded into the URL itself. We don\'t run a backend and we don\'t see your policy content.',
    icon: 'lock',
  },
];

const iconPaths: Record<string, string> = {
  shield: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  puzzle: 'M19 11h-1V7a2 2 0 0 0-2-2h-4V4a2 2 0 1 0-4 0v1H4a2 2 0 0 0-2 2v4h1a2 2 0 1 1 0 4H2v4a2 2 0 0 0 2 2h4v-1a2 2 0 1 1 4 0v1h4a2 2 0 0 0 2-2v-4h1a2 2 0 1 0 0-4z',
  link: 'M10 13a5 5 0 0 0 7.07 0l3-3a5 5 0 0 0-7.07-7.07l-1.41 1.41M14 11a5 5 0 0 0-7.07 0l-3 3a5 5 0 0 0 7.07 7.07l1.41-1.41',
  download: 'M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3',
  file: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M16 13H8 M16 17H8 M10 9H8',
  lock: 'M19 11H5a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7a2 2 0 0 0-2-2z M7 11V7a5 5 0 0 1 10 0v4',
};

// Map icon names to de.json feature card keys
const iconToCardKey: Record<string, string> = {
  shield: 'laws',
  puzzle: 'stack',
  link: 'url',
  download: 'export',
  file: 'legal',
  lock: 'privacy',
};
---
<section class="border-t border-border">
  <div class="mx-auto max-w-6xl px-6 py-20">
    <div class="text-center mb-14">
      <p class="text-xs uppercase tracking-widest text-fg-faint mb-2" data-i18n="features.label">Features</p>
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight" data-i18n="features.heading">Everything you need. Nothing you don't.</h2>
      <p class="mt-3 text-fg-muted max-w-2xl mx-auto" data-i18n="features.subtext">A privacy policy generator designed for indie developers, small teams, and anyone who needs a real policy without paying a lawyer $500.</p>
    </div>
    <div class="grid gap-px bg-border sm:grid-cols-2 lg:grid-cols-3 rounded-card overflow-hidden">
      {features.map((f) => (
        <div class="bg-bg-elevated p-7">
          <div class="inline-flex h-9 w-9 items-center justify-center rounded-md bg-bg-card border border-border mb-4">
            <svg class="h-4.5 w-4.5 text-fg-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d={iconPaths[f.icon]}></path>
            </svg>
          </div>
          <h3 class="text-base font-medium mb-1.5" data-i18n={`features.cards.${iconToCardKey[f.icon]}.title`}>{f.title}</h3>
          <p class="text-sm text-fg-muted leading-relaxed" data-i18n={`features.cards.${iconToCardKey[f.icon]}.body`}>{f.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

---
// src/components/sections/Comparison.astro
// Cell values use data-i18n to reference comparison.values.* keys in en.json
const rowKeys = ['price', 'time', 'gdprCovers', 'tailored', 'updatable', 'url', 'review'];

// Value keys per row: [privacyPolGen, lawyer, paidTemplate]
const valueKeys = [
  ['free', 'lawyerPrice', 'paidPrice'],
  ['seconds', 'days', 'daysShort'],
  ['yes', 'yesCustom', 'yesTemplate'],
  ['yesServices', 'yesAttorney', 'partially'],
  ['yes', 'no', 'no'],
  ['yes', 'pdfOnly', 'no'],
  ['recommended', 'included', 'recommended'],
];
---
<section class="border-t border-border">
  <div class="mx-auto max-w-5xl px-6 py-20">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight" data-i18n="comparison.heading">PrivacyPolGen vs. the alternatives.</h2>
    </div>
    <div class="rounded-card border border-border bg-bg-elevated overflow-x-auto">
      <div class="grid grid-cols-4 text-sm min-w-[580px]">
        <div class="p-4 text-xs text-fg-faint border-b border-border"></div>
        <div class="p-4 font-medium text-center border-b border-l border-border bg-bg-card" data-i18n="comparison.colPrivacyPolGen">PrivacyPolGen</div>
        <div class="p-4 text-fg-muted text-center border-b border-l border-border" data-i18n="comparison.colLawyer">Lawyer</div>
        <div class="p-4 text-fg-muted text-center border-b border-l border-border" data-i18n="comparison.colPaidTemplate">Paid template</div>
        {rowKeys.map((rowKey, i) => (
          <>
            <div class="p-4 text-fg-muted border-t border-border" data-i18n={`comparison.rows.${rowKey}`}>{rowKey}</div>
            <div class="p-4 text-center border-t border-l border-border bg-bg-card font-medium" data-i18n={`comparison.values.${valueKeys[i][0]}`}>{valueKeys[i][0]}</div>
            <div class="p-4 text-center text-fg-muted border-t border-l border-border" data-i18n={`comparison.values.${valueKeys[i][1]}`}>{valueKeys[i][1]}</div>
            <div class="p-4 text-center text-fg-muted border-t border-l border-border" data-i18n={`comparison.values.${valueKeys[i][2]}`}>{valueKeys[i][2]}</div>
          </>
        ))}
      </div>
    </div>
  </div>
</section>

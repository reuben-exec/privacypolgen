---
// src/components/sections/Pricing.astro
// LemonSqueezy checkout link is resolved at build time from .env
const lemonSqueezyUrl = import.meta.env.LEMONSQUEEZY_CHECKOUT_URL || '';
const premiumAvailable = lemonSqueezyUrl.length > 0;

const plans = [
  {
    id: 'free',
    name: 'Free',
    price: '$0',
    period: 'forever',
    description: 'For personal projects, blogs, and small sites.',
    cta: 'Generate your policy',
    href: '/generate',
    highlight: false,
    features: [
      'Complete privacy policy in Markdown, HTML, and plain text',
      'GDPR, CCPA, COPPA, PIPEDA, LGPD, PDPA-SG',
      'All 25+ third-party service disclosures',
      'Shareable public URL',
      'Unlimited regenerations',
      'No account required',
    ],
  },
  {
    id: 'premium',
    name: 'Premium',
    price: '$19',
    period: 'one-time',
    description: 'For businesses that need polished exports and integrations.',
    cta: premiumAvailable ? 'Upgrade to Premium' : 'Coming soon',
    href: premiumAvailable ? lemonSqueezyUrl : '#',
    external: premiumAvailable,
    highlight: true,
    features: [
      'Everything in Free',
      'PDF and DOCX export',
      'Cookie banner code generator',
      'Custom branding (your logo + colors)',
      'Hosted policy page with custom domain',
      'Version history & diffs',
      'Priority support',
    ],
  },
];
---
<section class="border-t border-border">
  <div class="mx-auto max-w-6xl px-6 py-20">
    <div class="text-center mb-14">
      <p class="text-xs uppercase tracking-widest text-fg-faint mb-2" data-i18n="pricing.label">Pricing</p>
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight" data-i18n="pricing.heading">Free for everyone. Premium for the polished stuff.</h2>
      <p class="mt-3 text-fg-muted max-w-2xl mx-auto" data-i18n="pricing.subtext">The core generator is free and will stay free. Premium is for teams that need exports and customization.</p>
    </div>
    <div class="grid gap-px bg-border md:grid-cols-2 rounded-card overflow-hidden max-w-3xl mx-auto">
      {plans.map((p) => (
        <div class:list={['p-8 flex flex-col', p.highlight ? 'bg-bg-elevated' : 'bg-bg-elevated/60']}>
          <div class="flex items-baseline justify-between mb-3">
            <h3 class="text-lg font-medium" data-i18n={`pricing.plans.${p.id}.name`}>{p.name}</h3>
            {p.highlight && <span class="text-[10px] uppercase tracking-widest text-fg-muted border border-border rounded-full px-2 py-0.5" data-i18n="pricing.plans.premium.badge">Most useful</span>}
          </div>
          <div class="flex items-baseline gap-1.5 mb-1">
            <span class="text-3xl font-semibold tracking-tight" data-i18n={`pricing.plans.${p.id}.price`}>{p.price}</span>
            <span class="text-fg-faint text-sm" data-i18n={`pricing.plans.${p.id}.period`}>/ {p.period}</span>
          </div>
          <p class="text-sm text-fg-muted mb-6" data-i18n={`pricing.plans.${p.id}.description`}>{p.description}</p>
          <a
            href={p.href}
            {...(p.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            class:list={[
              'inline-flex h-10 items-center justify-center rounded-button font-medium text-sm transition-opacity hover:opacity-90 mb-6',
              p.highlight ? 'bg-fg text-bg' : 'border border-border bg-bg text-fg hover:bg-bg-elevated',
            ]}
            data-i18n={`pricing.plans.${p.id}.cta`}
          >{p.cta}</a>
          <ul class="space-y-2.5 text-sm text-fg-muted flex-1">
            {p.features.map((f, fi) => (
              <li class="flex gap-2" key={fi}>
                <svg class="h-4 w-4 text-fg-muted mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5L20 7"/></svg>
                <span data-i18n={`pricing.plans.${p.id}.features.${fi}`}>{f}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

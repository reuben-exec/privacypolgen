---
// src/components/sections/Pricing.astro
import { getTranslations, t } from '@/lib/i18n-server';
interface Props { locale?: string }
const { locale = 'en' } = Astro.props;
const tx = await getTranslations(locale);

// LemonSqueezy checkout link is resolved at build time from .env
const lemonSqueezyUrl = import.meta.env.PUBLIC_LEMONSQUEEZY_CHECKOUT_URL || '';
const premiumAvailable = lemonSqueezyUrl.length > 0;

const planIds = ['free', 'premium'] as const;
const freeFeatures = [0, 1, 2, 3, 4, 5] as const;
const premiumFeatures = [0, 1, 2, 3, 4, 5, 6] as const;
---
<section class="border-t border-border">
  <div class="mx-auto max-w-6xl px-6 py-20">
    <div class="text-center mb-14">
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight">{t(tx, 'pricing.heading')}</h2>
      <p class="mt-3 text-fg-muted max-w-2xl mx-auto">{t(tx, 'pricing.subtext')}</p>
    </div>
    <div class="grid gap-6 md:grid-cols-2 max-w-3xl mx-auto">
      {planIds.map((planId) => {
        const isPremium = planId === 'premium';
        const href = isPremium ? (premiumAvailable ? lemonSqueezyUrl : '#') : '/generate';
        const external = isPremium && premiumAvailable;
        return (
          <div class:list={['rounded-card border border-border p-8 flex flex-col', isPremium ? 'bg-bg-elevated ring-1 ring-fg/10 relative overflow-hidden before:absolute before:inset-x-0 before:top-0 before:h-0.5 before:bg-fg/15' : 'bg-bg-elevated/40']}>
            <div class="flex items-baseline justify-between mb-3">
              <h3 class="text-lg font-medium">{t(tx, `pricing.plans.${planId}.name`)}</h3>
              {isPremium && <span class="text-xs font-medium text-fg-muted border border-border rounded-full px-2 py-0.5">{t(tx, 'pricing.plans.premium.badge')}</span>}
            </div>
            <div class="flex items-baseline gap-1.5 mb-1">
              <span class="text-3xl font-semibold tracking-tight">{t(tx, `pricing.plans.${planId}.price`)}</span>
              <span class="text-fg-faint text-sm">/ {t(tx, `pricing.plans.${planId}.period`)}</span>
            </div>
            <p class="text-sm text-fg-muted mb-6">{t(tx, `pricing.plans.${planId}.description`)}</p>
            <a
              href={href}
              {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              class:list={[
                'inline-flex h-10 items-center justify-center rounded-button font-medium text-sm transition-opacity hover:opacity-90 mb-6',
                isPremium ? 'bg-fg text-bg' : 'border border-border bg-bg text-fg hover:bg-bg-elevated',
              ]}
            >{t(tx, `pricing.plans.${planId}.cta`)}</a>
            <ul class="space-y-2.5 text-sm text-fg-muted flex-1">
              {(isPremium ? premiumFeatures : freeFeatures).map((fi) => (
                <li class="flex gap-2" key={fi}>
                  <svg class="h-4 w-4 text-fg-muted mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5L20 7"/></svg>
                  <span>{t(tx, `pricing.plans.${planId}.features.${fi}`)}</span>
                </li>
              ))}
            </ul>
          </div>
        );
      })}
    </div>
  </div>
</section>

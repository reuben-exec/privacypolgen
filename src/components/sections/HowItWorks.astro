---
// src/components/sections/HowItWorks.astro
const steps = [
  { n: '01', title: 'Tell us about your business', body: 'Name, URL, business type, and where you operate. We use defaults for common cases.' },
  { n: '02', title: 'Pick what you collect', body: 'Check off the kinds of data you collect. Names, emails, payments, analytics, etc.' },
  { n: '03', title: 'List your services', body: 'Stripe, Google Analytics, Mailchimp, etc. We add the right third-party disclosures.' },
  { n: '04', title: 'Choose applicable laws', body: 'GDPR, CCPA, COPPA, PIPEDA, LGPD, PDPA-SG. We default to the strictest common case.' },
  { n: '05', title: 'Get your policy', body: 'Copy as Markdown, HTML, or plain text. Share via a public URL. Update any time.' },
];

const stepKeys = ['business', 'data', 'services', 'laws', 'policy'];
---
<section class="border-t border-border">
  <div class="mx-auto max-w-6xl px-6 py-20">
    <div class="text-center mb-14">
      <p class="text-xs uppercase tracking-widest text-fg-faint mb-2" data-i18n="howItWorks.label">How it works</p>
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight" data-i18n="howItWorks.heading">Five steps. About a minute.</h2>
    </div>
    <ol class="grid gap-4 md:grid-cols-5">
      {steps.map((s, i) => (
        <li class="relative rounded-card border border-border bg-bg-elevated p-5">
          <span class="block font-mono text-xs text-fg-faint mb-3">{s.n}</span>
          <h3 class="text-sm font-medium mb-1.5" data-i18n={`howItWorks.steps.${stepKeys[i]}.title`}>{s.title}</h3>
          <p class="text-xs text-fg-muted leading-relaxed" data-i18n={`howItWorks.steps.${stepKeys[i]}.body`}>{s.body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

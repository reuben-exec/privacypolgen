---
// src/components/sections/HowItWorks.astro
import { getTranslations, t } from '@/lib/i18n-server';
interface Props { locale?: string }
const { locale = 'en' } = Astro.props;
const tx = await getTranslations(locale);

const stepKeys = ['business', 'data', 'services', 'laws', 'policy'];
---
<section class="border-t border-border">
  <div class="mx-auto max-w-6xl px-6 py-20">
    <div class="text-center mb-14">
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight">{t(tx, 'howItWorks.heading')}</h2>
    </div>
    <ol class="grid gap-4 md:grid-cols-5" data-stagger-group>
      {stepKeys.map((key, i) => (
        <li class="stagger-item relative rounded-card border border-border bg-bg-elevated p-5">
          <span class="block font-mono text-xs text-fg-faint mb-3">0{i + 1}</span>
          <h3 class="text-sm font-medium mb-1.5">{t(tx, `howItWorks.steps.${key}.title`)}</h3>
          <p class="text-xs text-fg-muted leading-relaxed">{t(tx, `howItWorks.steps.${key}.body`)}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<script>
(function () {
  var group = document.querySelector('[data-stagger-group]')
  if (!group) return
  var items = group.querySelectorAll(':scope > .stagger-item')
  if (!items.length) return

  function showAll () {
    items.forEach(function (el) {
      el.classList.remove('is-hidden')
      el.classList.add('is-visible')
    })
  }

  function hideAll () {
    items.forEach(function (el) {
      el.classList.remove('is-visible')
      el.classList.add('is-hidden')
    })
  }

  var rect = group.getBoundingClientRect()
  if (rect.top < window.innerHeight && rect.bottom > 0) {
    showAll()
    return
  }

  hideAll()
  var observer = new IntersectionObserver(
    function (entries) {
      if (entries[0].isIntersecting) {
        showAll()
        observer.disconnect()
      }
    },
    { threshold: 0.1 }
  )
  observer.observe(group)
})()
</script>

<style>
  .lang-dropdown.open {
    visibility: visible;
    opacity: 1;
  }

  .lang-dropdown:not(.hidden) {
    box-shadow: var(--shadow-dropdown);
  }

  /* Project language icon via CSS mask — inherits currentColor for theming */
  .lang-icon {
    display: block;
    width: 20px;
    height: 20px;
    background-color: currentColor;
    -webkit-mask-image: url('/language-svgrepo-com.svg');
    mask-image: url('/language-svgrepo-com.svg');
    -webkit-mask-size: contain;
    mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
  }

  /* Scrollbar for long dropdown */
  .lang-dropdown::-webkit-scrollbar {
    width: 4px;
  }
  .lang-dropdown::-webkit-scrollbar-track {
    background: transparent;
  }
  .lang-dropdown::-webkit-scrollbar-thumb {
    background: var(--color-border-strong);
    border-radius: 2px;
  }
</style>

<script>
  import { getCurrentLocale, setLocale } from '@/lib/i18n';

  const container = document.querySelector('[data-lang-switcher]');
  if (!container) throw new Error('LangSwitcher: [data-lang-switcher] not found');

  const toggle = /** @type {HTMLButtonElement} */ (container.querySelector('[data-lang-toggle]'));
  const dropdown = /** @type {HTMLDivElement} */ (container.querySelector('[data-lang-dropdown]'));
  const options = /** @type {HTMLDivElement[]} */ (Array.from(container.querySelectorAll('.lang-option')));

  let isOpen = false;
  let currentLang = getCurrentLocale();
  let focusedIndex = -1;

  // ─── UI Updates ───────────────────────────────────────────────

  /** Set aria-selected and check visibility for each option. */
  function updateDropdown(lang: string) {
    options.forEach((opt) => {
      const isSelected = opt.getAttribute('data-lang') === lang;
      opt.setAttribute('aria-selected', String(isSelected));
      const check = opt.querySelector('.lang-check');
      if (check) check.classList.toggle('hidden', !isSelected);
    });
  }

  function updateUI(lang: string) {
    currentLang = lang;
    updateDropdown(lang);
  }

  /** Scroll option into view within the dropdown (no page scrolling). */
  function scrollIntoDropdown(opt: HTMLElement) {
    if (!dropdown || !opt) return;
    const optTop = opt.offsetTop;
    const optBottom = optTop + opt.offsetHeight;
    const scrollTop = dropdown.scrollTop;
    const height = dropdown.clientHeight;
    if (optTop < scrollTop) {
      dropdown.scrollTop = optTop;
    } else if (optBottom > scrollTop + height) {
      dropdown.scrollTop = optBottom - height;
    }
  }

  // ─── Open / Close ─────────────────────────────────────────────

  function open() {
    if (isOpen) return;
    isOpen = true;

    toggle.setAttribute('aria-expanded', 'true');
    dropdown.hidden = false; // remove from display:none
    // Force reflow so the visibility/opacity transition plays
    // eslint-disable-next-line @typescript-eslint/no-unused-expressions
    void dropdown.offsetWidth;
    dropdown.classList.add('open');

    // Focus the currently selected option, or the first one
    focusedIndex = options.findIndex((o) => o.getAttribute('data-lang') === currentLang);
    if (focusedIndex === -1) focusedIndex = 0;
    options[focusedIndex]?.focus();
  }

  function close() {
    if (!isOpen) return;
    isOpen = false;

    toggle.setAttribute('aria-expanded', 'false');
    dropdown.classList.remove('open');
    dropdown.hidden = true;
    toggle.focus();
  }

  // ─── Select Language ──────────────────────────────────────────

  function selectLang(lang: string) {
    if (lang && lang !== currentLang) {
      setLocale(lang); // dispatches 'localechange' CustomEvent
    }
    updateUI(lang);
    close();
  }

  // ─── Event Wiring ─────────────────────────────────────────────

  // Toggle click
  toggle.addEventListener('click', () => {
    isOpen ? close() : open();
  });

  // Toggle keyboard — open on Enter/Space/ArrowDown
  toggle.addEventListener('keydown', (e: Event) => {
    if (e.key === 'Enter' || e.key === ' ' || e.key === 'ArrowDown') {
      e.preventDefault();
      open();
    }
  });

  // Dropdown keyboard navigation
  dropdown.addEventListener('keydown', (e: Event) => {
    switch (e.key) {
      case 'Escape':
      case 'Tab':
        e.preventDefault();
        close();
        break;
      case 'ArrowDown':
        e.preventDefault();
        if (options.length === 0) break;
        focusedIndex = (focusedIndex + 1) % options.length;
        options[focusedIndex]?.focus();
        scrollIntoDropdown(/** @type {HTMLElement} */ (options[focusedIndex]));
        break;
      case 'ArrowUp':
        e.preventDefault();
        if (options.length === 0) break;
        focusedIndex = (focusedIndex - 1 + options.length) % options.length;
        options[focusedIndex]?.focus();
        scrollIntoDropdown(/** @type {HTMLElement} */ (options[focusedIndex]));
      case 'Enter':
      case ' ':
        e.preventDefault();
        selectLang(options[focusedIndex]?.getAttribute('data-lang') ?? '');
        break;
    }
  });

  // Option click
  options.forEach((opt) => {
    opt.addEventListener('click', () => {
      selectLang(opt.getAttribute('data-lang') ?? '');
    });
  });

  // Click outside — close dropdown
  document.addEventListener('click', (e: Event) => {
    if (isOpen && container && !container.contains(/** @type {Node} */ (e.target))) {
      close();
    }
  });

  // React to external locale changes (e.g. from React I18nProvider)
  window.addEventListener('localechange', (e: Event) => {
    const lang = (/** @type {CustomEvent} */ (e)).detail?.locale;
    if (lang && lang !== currentLang) {
      updateUI(lang);
    }
  });

  // ─── Bootstrap ────────────────────────────────────────────────

  updateUI(currentLang);
</script>

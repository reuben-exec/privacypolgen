---
// src/components/LangSwitcher.astro
// Language switcher: icon button trigger + dropdown listbox.
// Uses the project's own language-icon.svg via CSS mask for currentColor theming.
// Calls setLocale() from i18n.ts which dispatches a 'localechange' CustomEvent.
// Both the Layout.astro i18n script and React I18nProvider listen for this event,
// so switching language no longer requires a page reload.
//
// Accessibility: ARIA listbox pattern with keyboard navigation (Escape, arrows,
// Enter/Space). Focus is trapped inside the dropdown when open.
---

<div class="relative" data-lang-switcher>
  <button
    type="button"
    class="inline-flex h-8 w-8 items-center justify-center rounded-button border border-border text-fg-muted transition-colors hover:bg-bg-hover hover:text-fg focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-text"
    data-lang-toggle
    aria-haspopup="listbox"
    aria-expanded="false"
    aria-label="Switch language"
    title="Switch language"
  >
    <!-- Project language icon — uses CSS mask so it inherits currentColor -->
    <span class="lang-icon" aria-hidden="true"></span>
  </button>

  <!-- Dropdown listbox -->
  <div
    class="lang-dropdown invisible absolute right-0 top-full mt-1.5 w-44 max-h-80 overflow-y-auto rounded-card border border-border bg-bg-elevated z-dropdown opacity-0 transition-all duration-150"
    data-lang-dropdown
    role="listbox"
    aria-label="Select language"
    tabindex="-1"
    hidden

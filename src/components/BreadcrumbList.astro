---
// src/components/BreadcrumbList.astro
// Visual breadcrumb navigation + JSON-LD schema
export interface Props {
  items: Array<{ name: string; url?: string }>;
}
import { getTranslations, t } from '@/lib/i18n-server';
const { items } = Astro.props;
const tx = await getTranslations();
---

<nav class="mx-auto max-w-6xl px-6 py-4" aria-label={t(tx, 'breadcrumb.ariaLabel')}>
  <ol class="flex items-center gap-2 text-sm text-fg-muted" itemscope itemtype="https://schema.org/BreadcrumbList">
    {items.map((item, i) => (
      <li class="flex items-center gap-2" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content={i + 1} />
        {item.url ? (
          <a href={item.url} itemprop="item" class="hover:underline underline-offset-2 transition-colors">
            <span itemprop="name">{item.name}</span>
          </a>
        ) : (
          <span itemprop="name" class="text-fg">{item.name}</span>
        )}
        {i < items.length - 1 && (
          <svg class="h-3 w-3 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M9 18l6-6-6-6" />
          </svg>
        )}
      </li>
    ))}
  </ol>
</nav>

<!-- JSON-LD BreadcrumbList is handled by SeoHead when schemaType="BreadcrumbList" -->
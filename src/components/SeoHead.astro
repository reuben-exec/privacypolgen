---
// src/components/SeoHead.astro
export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  schemaType?: 'WebApplication' | 'FAQPage' | 'WebPage';
}
const { title, description, canonical, ogType = 'website', noindex = false, schemaType = 'WebApplication' } = Astro.props;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
{noindex && <meta name="robots" content="noindex,nofollow" />}

<!-- Open Graph -->
<meta property="og:type" content={ogType} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:site_name" content="PrivacyPolGen" />
<meta property="og:image" content={new URL('/og.png', Astro.site).toString()} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="PrivacyPolGen — generate a privacy policy in 60 seconds." />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL('/og.png', Astro.site).toString()} />

<!-- JSON-LD: {schemaType} -->
<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': schemaType,
  name: 'PrivacyPolGen',
  description: 'Free privacy policy generator for websites, SaaS, e-commerce, and mobile apps.',
  url: 'https://privacypolgen.com',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Any',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
})} />

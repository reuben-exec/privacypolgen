---
// src/components/SeoHead.astro
export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  schemaType?: 'WebApplication' | 'FAQPage' | 'WebPage' | 'Article' | 'BreadcrumbList';
  // Article-specific props
  article?: {
    publishedTime: string;
    modifiedTime?: string;
    author?: string;
    section?: string;
    tags?: string[];
  };
  // BreadcrumbList-specific props
  breadcrumbs?: Array<{ name: string; url: string }>;
}

const { title, description, canonical, ogType = 'website', noindex = false, schemaType = 'WebApplication', article, breadcrumbs } = Astro.props;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();

function buildSchema() {
  const base = {
    '@context': 'https://schema.org',
  };

  // SoftwareApplication (default for homepage/generator)
  if (schemaType === 'WebApplication') {
    return {
      ...base,
      '@type': 'SoftwareApplication',
      name: 'PrivacyPolGen',
      description: 'Free privacy policy generator for websites, SaaS, e-commerce, and mobile apps.',
      url: 'https://privacypolgen.com',
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Any',
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'USD',
      },
    };
  }

  // FAQPage (for pages with FAQ section)
  if (schemaType === 'FAQPage') {
    // This is handled by FAQ.astro component directly
    return null;
  }

  // Article (for blog posts)
  if (schemaType === 'Article' && article) {
    return {
      ...base,
      '@type': 'Article',
      headline: title,
      description: description,
      url: canonicalUrl,
      datePublished: article.publishedTime,
      dateModified: article.modifiedTime ?? article.publishedTime,
      author: {
        '@type': 'Person',
        name: article.author ?? 'Reuben Richard Lancer',
      },
      publisher: {
        '@type': 'Person',
        name: 'Reuben Richard Lancer',
        url: 'https://github.com/reuben-exec',
      },
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': canonicalUrl,
      },
      articleSection: article.section,
      keywords: article.tags?.join(', '),
    };
  }

  // WebPage (enhanced for general pages)
  if (schemaType === 'WebPage') {
    return {
      ...base,
      '@type': 'WebPage',
      name: title,
      description: description,
      url: canonicalUrl,
      inLanguage: 'en',
      potentialAction: {
        '@type': 'SearchAction',
        target: {
          '@type': 'EntryPoint',
          urlTemplate: 'https://privacypolgen.com/generate',
        },
        'query-input': 'required name=search_term_string',
      },
    };
  }

  // BreadcrumbList
  if (schemaType === 'BreadcrumbList' && breadcrumbs && breadcrumbs.length > 0) {
    return {
      ...base,
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumbs.map((b, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: b.name,
        item: b.url,
      })),
    };
  }

  return null;
}
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
{noindex && <meta name="robots" content="noindex,nofollow" />}

<!-- Open Graph -->
<meta property="og:type" content={ogType} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:site_name" content="PrivacyPolGen" />
<meta property="og:image" content={new URL('/og.png', Astro.site).toString()} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="PrivacyPolGen — Free privacy policy generator for websites and apps." />
{article && article.publishedTime && <meta property="article:published_time" content={article.publishedTime} />}
{article && article.modifiedTime && <meta property="article:modified_time" content={article.modifiedTime} />}
{article && article.author && <meta property="article:author" content={article.author} />}
{article && article.section && <meta property="article:section" content={article.section} />}
{article && article.tags && article.tags.map(tag => <meta property="article:tag" content={tag} />)}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@classic_bruv04" />
<meta name="twitter:creator" content="@classic_bruv04" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL('/og.png', Astro.site).toString()} />
{article && article.tags && article.tags.length > 0 && <meta name="keywords" content={article.tags.join(', ')} />}

<!-- JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify(buildSchema())} />
<script type="application/ld+json">{
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Reuben Richard Lancer",
  "url": "https://github.com/reuben-exec",
  "description": "Creator of PrivacyPolGen — free privacy policy generator for websites, SaaS, e-commerce, and mobile apps.",
  "sameAs": [
    "https://github.com/reuben-exec",
    "https://x.com/classic_bruv04"
  ]
}</script></script>

---
// src/pages/maintenance.astro
// Under Maintenance page — shown when the site is temporarily offline for improvements.
import Layout from '@/layouts/Layout.astro';
import { getTranslations, t } from '@/lib/i18n-server';

const tx = await getTranslations();
---
<Layout
  title={t(tx, 'maintenance.title')}
  description={t(tx, 'maintenance.description')}
  noindex={true}
>
  <!-- Hero -->
  <section class="border-b border-border bg-bg-elevated/30">
    <div class="mx-auto max-w-3xl px-6 pt-24 pb-12 text-center">
      <!-- Wrench icon -->
      <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-fg/10">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-8 w-8">
          <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />
        </svg>
      </div>
      <h1 class="text-3xl md:text-4xl font-semibold tracking-tight">{t(tx, 'maintenance.heading')}</h1>
      <p class="mt-3 text-fg-muted max-w-lg mx-auto">{t(tx, 'maintenance.subtext')}</p>
    </div>
  </section>

  <!-- Work In Progress -->
  <section class="mx-auto max-w-2xl px-6 py-16">
    <div class="rounded-card border border-border bg-bg-elevated p-8">
      <h2 class="text-lg font-semibold tracking-tight mb-6">What I'm working on</h2>
      <ul class="space-y-4">
        <li class="flex items-start gap-3">
          <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-lg bg-fg/5 text-fg">
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 20v-9"/>
              <path d="M14 7a4 4 0 0 1 4 4v3a6 6 0 0 1-12 0v-3a4 4 0 0 1 4-4z"/>
              <path d="M14.12 3.88 16 2"/>
              <path d="M21 21a4 4 0 0 0-3.81-4"/>
              <path d="M21 5a4 4 0 0 1-3.55 3.97"/>
              <path d="M22 13h-4"/>
              <path d="M3 21a4 4 0 0 1 3.81-4"/>
              <path d="M3 5a4 4 0 0 0 3.55 3.97"/>
              <path d="M6 13H2"/>
              <path d="m8 2 1.88 1.88"/>
              <path d="M9 7.13V6a3 3 0 1 1 6 0v1.13"/>
            </svg>
          </span>
          <span class="text-sm text-fg-muted">{t(tx, 'maintenance.status.fixes')}</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-lg bg-fg/5 text-fg">
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </span>
          <span class="text-sm text-fg-muted">{t(tx, 'maintenance.status.analytics')}</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-lg bg-fg/5 text-fg">
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </span>
          <span class="text-sm text-fg-muted">{t(tx, 'maintenance.status.paywall')}</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-lg bg-fg/5 text-fg">
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <path d="M3 9h18"/>
            </svg>
          </span>
          <span class="text-sm text-fg-muted">{t(tx, 'maintenance.status.adsense')}</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-lg bg-fg/5 text-fg">
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z"/>
              <path d="M14 2v5a1 1 0 0 0 1 1h5"/>
              <path d="M10 12.5 8 15l2 2.5"/>
              <path d="m14 12.5 2 2.5-2 2.5"/>
            </svg>
          </span>
          <span class="text-sm text-fg-muted">{t(tx, 'maintenance.status.cleanup')}</span>
        </li>
      </ul>
    </div>

    <!-- Note -->
    <div class="mt-8 text-center">
      <p class="text-sm text-fg-muted">
        {t(tx, 'maintenance.note')}
        {' '}
        <a href="/contact" class="underline underline-offset-2 hover:text-fg transition-colors">
          {t(tx, 'maintenance.contact')}
        </a>.
      </p>
    </div>
  </section>
</Layout>

---
// src/pages/contact.astro
import Layout from '@/layouts/Layout.astro';
---

<Layout
  title="Contact — PrivacyPolGen"
  description="Get in touch with PrivacyPolGen. Reach us at support@privacypolgen.com."
>
  <section class="border-b border-border bg-bg-elevated/30">
    <div class="mx-auto max-w-3xl px-6 py-10">
      <p class="text-sm text-fg-muted" data-i18n="contactPage.breadcrumb">Contact</p>
      <h1 class="text-3xl md:text-4xl font-semibold tracking-tight" data-i18n="contactPage.heading">Get in touch</h1>
      <p class="mt-2 text-fg-muted max-w-2xl" data-i18n="contactPage.subtext">Questions, feedback, or just saying hi? We'd love to hear from you.</p>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-6 py-16">
    <div class="grid gap-8 md:grid-cols-2">
      <!-- Email -->
      <div class="rounded-card border border-border bg-bg-elevated p-8">
        <div class="flex items-center gap-3 mb-4">
          <div class="flex h-10 w-10 items-center justify-center rounded-full bg-fg/10">
            <svg class="h-5 w-5 text-fg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <div>
            <h2 class="text-lg font-semibold tracking-tight" data-i18n="contactPage.email.title">Email</h2>
            <p class="text-sm text-fg-muted" data-i18n="contactPage.email.body">We typically respond within 24 hours.</p>
          </div>
        </div>
        <a href="mailto:support@privacypolgen.com" class="text-sm font-medium text-fg underline underline-offset-2 hover:opacity-80">
          support@privacypolgen.com
        </a>
      </div>

      <!-- GitHub -->
      <div class="rounded-card border border-border bg-bg-elevated p-8">
        <div class="flex items-center gap-3 mb-4">
          <div class="flex h-10 w-10 items-center justify-center rounded-full bg-fg/10">
            <svg class="h-5 w-5 text-fg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </div>
          <div>
            <h2 class="text-lg font-semibold tracking-tight" data-i18n="contactPage.github.title">GitHub</h2>
            <p class="text-sm text-fg-muted" data-i18n="contactPage.github.body">Report issues or contribute.</p>
          </div>
        </div>
        <a href="https://github.com/privacypolgen" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-fg underline underline-offset-2 hover:opacity-80">
          github.com/privacypolgen
        </a>
      </div>

      <!-- Feature Request -->
      <div class="rounded-card border border-border bg-bg-elevated p-8">
        <div class="flex items-center gap-3 mb-4">
          <div class="flex h-10 w-10 items-center justify-center rounded-full bg-fg/10">
            <svg class="h-5 w-5 text-fg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          </div>
          <div>
            <h2 class="text-lg font-semibold tracking-tight" data-i18n="contactPage.feature.title">Feature Request</h2>
            <p class="text-sm text-fg-muted" data-i18n="contactPage.feature.body">Have an idea? We'd love to hear it.</p>
          </div>
        </div>
        <a href="mailto:support@privacypolgen.com?subject=Feature%20Request" class="text-sm font-medium text-fg underline underline-offset-2 hover:opacity-80">
          Send us a suggestion →
        </a>
      </div>

      <!-- Legal -->
      <div class="rounded-card border border-border bg-bg-elevated p-8">
        <div class="flex items-center gap-3 mb-4">
          <div class="flex h-10 w-10 items-center justify-center rounded-full bg-fg/10">
            <svg class="h-5 w-5 text-fg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
              <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
              <line x1="12" y1="19" x2="12" y2="23"/>
              <line x1="8" y1="23" x2="16" y2="23"/>
            </svg>
          </div>
          <div>
            <h2 class="text-lg font-semibold tracking-tight" data-i18n="contactPage.legal.title">Legal Inquiry</h2>
            <p class="text-sm text-fg-muted" data-i18n="contactPage.legal.body">For legal questions or requests.</p>
          </div>
        </div>
        <a href="mailto:legal@privacypolgen.com" class="text-sm font-medium text-fg underline underline-offset-2 hover:opacity-80">
          legal@privacypolgen.com
        </a>
      </div>
    </div>
  </section>
</Layout>

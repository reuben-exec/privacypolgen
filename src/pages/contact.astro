---
// src/pages/contact.astro
import Layout from '@/layouts/Layout.astro';
import BreadcrumbList from '@/components/BreadcrumbList.astro';
import { getTranslations, t } from '@/lib/i18n-server';

const locale = 'en';
const tx = await getTranslations(locale);

const TURNSTILE_SITE_KEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || '';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Contact', url: '/contact' },
];
---

<Layout
  title="Contact — PrivacyPolGen"
  description="Get in touch. Email me at benatwork4747@gmail.com."
  schemaType="BreadcrumbList"
  breadcrumbs={breadcrumbs}
>
  <BreadcrumbList items={breadcrumbs} />
  <section class="border-b border-border bg-bg-elevated/30">
    <div class="mx-auto max-w-3xl px-6 py-10">
      <p class="text-sm text-fg-muted">{t(tx, 'contactPage.breadcrumb')}</p>
      <h1 class="text-3xl md:text-4xl font-semibold tracking-tight">{t(tx, 'contactPage.heading')}</h1>
      <p class="mt-2 text-fg-muted max-w-2xl">{t(tx, 'contactPage.subtext')}</p>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="mx-auto max-w-3xl px-6 py-16">
    <!-- Success state -->
    <div id="contact-success" class="hidden rounded-card border border-border bg-bg-elevated p-8 text-center">
      <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-fg/10">
        <svg class="h-8 w-8 text-fg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
          <polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
      </div>
      <h2 class="text-2xl font-semibold tracking-tight mb-2">{t(tx, 'contactPage.form.successTitle')}</h2>
      <p class="text-fg-muted max-w-md mx-auto">{t(tx, 'contactPage.form.successBody')}</p>
      <a
        href="/contact"
        class="mt-6 inline-flex h-10 items-center rounded-button bg-fg text-bg text-sm font-medium px-5 transition-opacity hover:opacity-90"
      >{t(tx, 'contactPage.form.successLink')}</a>
    </div>

    <!-- Error state -->
    <div id="contact-error" class="hidden mb-8 rounded-card border border-red-500/30 bg-red-500/10 p-4 text-sm text-red-600 dark:text-red-400">
      <div class="flex items-start gap-3">
        <svg class="mt-0.5 h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <span id="contact-error-text">{t(tx, 'contactPage.form.errorMessage')}</span>
      </div>
    </div>

    <!-- The form -->
    <div id="contact-form-wrapper">
      <form id="contact-form" class="contact-form rounded-card border border-border bg-bg-elevated p-6 md:p-8 space-y-6">
        <!-- Name -->
        <div>
          <label for="cf-name" class="label">{t(tx, 'contactPage.form.nameLabel')}</label>
          <input
            type="text"
            id="cf-name"
            name="name"
            required
            placeholder={t(tx, 'contactPage.form.namePlaceholder')}
            class="input mt-1.5"
          />
        </div>

        <!-- Email -->
        <div>
          <label for="cf-email" class="label">{t(tx, 'contactPage.form.emailLabel')}</label>
          <input
            type="email"
            id="cf-email"
            name="email"
            placeholder={t(tx, 'contactPage.form.emailPlaceholder')}
            class="input mt-1.5"
          />
        </div>

        <!-- Type -->
        <div>
          <label for="cf-type" class="label">{t(tx, 'contactPage.form.typeLabel')}</label>
          <select
            id="cf-type"
            name="type"
            class="input mt-1.5 appearance-none bg-no-repeat"
            style="background-image: url(\"data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%2371717a' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e\"); background-position: right 0.75rem center; background-size: 1.25rem;"
          >
            <option value="contact">{t(tx, 'contactPage.form.typeGeneral')}</option>
            <option value="bug">{t(tx, 'contactPage.form.typeBug')}</option>
            <option value="feature">{t(tx, 'contactPage.form.typeFeature')}</option>
          </select>
        </div>

        <!-- Message -->
        <div>
          <label for="cf-message" class="label">{t(tx, 'contactPage.form.messageLabel')}</label>
          <textarea
            id="cf-message"
            name="message"
            required
            rows="5"
            placeholder={t(tx, 'contactPage.form.messagePlaceholder')}
            class="input mt-1.5 resize-y min-h-[120px]"
          ></textarea>
        </div>

        <!-- Turnstile -->
        {TURNSTILE_SITE_KEY && (
          <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY} data-theme="auto"></div>
        )}

        <!-- Submit -->
        <button
          type="submit"
          id="contact-submit"
          class="btn-primary w-full"
        >{t(tx, 'contactPage.form.submit')}</button>
      </form>
    </div>

    <!-- Social links below form -->
    <div class="mt-16">
      <div class="grid gap-8 md:grid-cols-2">
        <!-- Email -->
        <div class="rounded-card border border-border bg-bg-elevated p-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-fg/10">
              <svg class="h-5 w-5 text-fg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div>
              <h2 class="text-lg font-semibold tracking-tight">{t(tx, 'contactPage.email.title')}</h2>
              <p class="text-sm text-fg-muted">{t(tx, 'contactPage.email.body')}</p>
            </div>
          </div>
          <a href="mailto:benatwork4747@gmail.com" class="text-sm font-medium text-fg underline underline-offset-2 hover:opacity-80">
            benatwork4747@gmail.com
          </a>
        </div>

        <!-- GitHub -->
        <div class="rounded-card border border-border bg-bg-elevated p-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-fg/10">
              <svg class="h-5 w-5 text-fg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            </div>
            <div>
              <h2 class="text-lg font-semibold tracking-tight">{t(tx, 'contactPage.github.title')}</h2>
              <p class="text-sm text-fg-muted">{t(tx, 'contactPage.github.body')}</p>
            </div>
          </div>
          <a href="https://github.com/reuben-exec" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-fg underline underline-offset-2 hover:opacity-80">
            github.com/reuben-exec
          </a>
        </div>

        <!-- X (Twitter) -->
        <div class="rounded-card border border-border bg-bg-elevated p-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-fg/10">
              <svg class="h-5 w-5 text-fg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </div>
            <div>
              <h2 class="text-lg font-semibold tracking-tight">{t(tx, 'contactPage.x.title')}</h2>
              <p class="text-sm text-fg-muted">{t(tx, 'contactPage.x.body')}</p>
            </div>
          </div>
          <a href="https://x.com/classic_bruv04" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-fg underline underline-offset-2 hover:opacity-80">
            @classic_bruv04
          </a>
        </div>

        <!-- Instagram -->
        <div class="rounded-card border border-border bg-bg-elevated p-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-fg/10">
              <svg class="h-5 w-5 text-fg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
              </svg>
            </div>
            <div>
              <h2 class="text-lg font-semibold tracking-tight">{t(tx, 'contactPage.instagram.title')}</h2>
              <p class="text-sm text-fg-muted">{t(tx, 'contactPage.instagram.body')}</p>
            </div>
          </div>
          <a href="https://www.instagram.com/ben_cant_code/" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-fg underline underline-offset-2 hover:opacity-80">
            @ben_cant_code
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .contact-form .label {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-fg-muted);
  }
  .contact-form .input {
    background-color: var(--color-bg);
    border-color: var(--color-border);
  }
  .contact-form .input:focus {
    border-color: var(--color-fg-faint);
    background-color: var(--color-bg);
  }
</style>

<script is:inline define:vars={{ TURNSTILE_SITE_KEY }}>
  (function () {
    const form = document.getElementById('contact-form');
    const submitBtn = document.getElementById('contact-submit');
    const wrapper = document.getElementById('contact-form-wrapper');
    const successEl = document.getElementById('contact-success');
    const errorEl = document.getElementById('contact-error');
    const errorText = document.getElementById('contact-error-text');

    if (!form) return;

    form.addEventListener('submit', async function (e) {
      e.preventDefault();

      // Get Turnstile token if widget exists
      let turnstileToken = '';
      const turnstileWidget = form.querySelector('.cf-turnstile');
      if (turnstileWidget && typeof turnstile !== 'undefined') {
        turnstileToken = turnstile.getResponse(turnstileWidget);
        if (!turnstileToken) {
          // Try to get from hidden input
          const hiddenInput = turnstileWidget.querySelector('[name="cf-turnstile-response"]');
          if (hiddenInput) turnstileToken = hiddenInput.value;
        }
      }

      // Also check for a direct hidden input (some Turnstile integrations add this)
      if (!turnstileToken) {
        const directInput = form.querySelector('input[name="cf-turnstile-response"]');
        if (directInput) turnstileToken = directInput.value;
      }

      // If Turnstile is configured but no token, warn
      if (TURNSTILE_SITE_KEY && !turnstileToken) {
        errorEl.classList.remove('hidden');
        errorText.textContent = 'Please complete the CAPTCHA.';
        return;
      }

      // Disable button
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';

      const data = {
        name: form.querySelector('#cf-name').value,
        email: form.querySelector('#cf-email').value,
        type: form.querySelector('#cf-type').value,
        message: form.querySelector('#cf-message').value,
        turnstileToken,
      };

      try {
        const res = await fetch('/api/feedback', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        const result = await res.json();

        if (result.success) {
          wrapper.classList.add('hidden');
          successEl.classList.remove('hidden');
        } else {
          errorEl.classList.remove('hidden');
          errorText.textContent = result.error || 'Something went wrong.';
          submitBtn.disabled = false;
          submitBtn.textContent = 'Send Message';
        }
      } catch {
        errorEl.classList.remove('hidden');
        errorText.textContent = 'Network error. Please try again.';
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send Message';
      }
    });
  })();
</script>

<!-- Load Turnstile if site key is present -->
{TURNSTILE_SITE_KEY && (
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
)}

---
// src/pages/examples.astro
import Layout from '@/layouts/Layout.astro';
import { encodePolicyToHash } from '@/lib/generator';

// Pre-baked sample policies. Each is a self-contained URL.
// Titles and descriptions use data-i18n for translation.
const samples: { i18nKey: string; hash: string; tags: string[]; enTitle: string; enDescription: string }[] = [
  {
    i18nKey: 'blog',
    hash: encodePolicyToHash({
      businessName: 'Quiet Letters',
      websiteUrl: 'https://quietletters.example',
      businessType: 'personal-blog',
      jurisdiction: 'United States',
      dataCollected: ['emails', 'analytics', 'cookies'],
      serviceIds: ['plausible', 'mailchimp', 'cloudflare'],
      lawIds: ['gdpr', 'ccpa', 'caloppa'],
      contactEmail: 'hello@quietletters.example',
      hasDpo: false,
      tone: 'professional',
    }),
    tags: ['Blog', 'GDPR', 'CCPA'],
    enTitle: 'Personal blog with newsletter',
    enDescription: 'Minimal data collection: email via newsletter, basic analytics, cookies. Covers GDPR, CCPA, CalOPPA.',
  },
  {
    i18nKey: 'saas',
    hash: encodePolicyToHash({
      businessName: 'Lumen',
      websiteUrl: 'https://lumen.example',
      businessType: 'saas',
      jurisdiction: 'United States',
      dataCollected: ['emails', 'names', 'user-accounts', 'payments', 'usage-data', 'analytics', 'cookies', 'device-info'],
      serviceIds: ['google-analytics', 'stripe', 'sendgrid', 'aws', 'cloudflare'],
      lawIds: ['gdpr', 'ccpa', 'caloppa', 'pipeda'],
      contactEmail: 'privacy@lumen.example',
      hasDpo: true,
      dpoEmail: 'dpo@lumen.example',
      tone: 'professional',
    }),
    tags: ['SaaS', 'GDPR', 'CCPA', 'DPO'],
    enTitle: 'SaaS application with payments',
    enDescription: 'Full SaaS: user accounts, payments via Stripe, email via SendGrid, analytics. Covers GDPR, CCPA, CalOPPA, PIPEDA.',
  },
  {
    i18nKey: 'ecommerce',
    hash: encodePolicyToHash({
      businessName: 'Northwind Goods',
      websiteUrl: 'https://shop.northwind.example',
      businessType: 'ecommerce',
      jurisdiction: 'United States',
      dataCollected: ['emails', 'names', 'addresses', 'phones', 'payments', 'analytics', 'cookies', 'ads'],
      serviceIds: ['google-analytics', 'stripe', 'paypal', 'google-adsense', 'facebook-pixel', 'cloudflare'],
      lawIds: ['gdpr', 'ccpa', 'caloppa', 'coppa'],
      contactEmail: 'privacy@shop.northwind.example',
      hasDpo: false,
      tone: 'professional',
    }),
    tags: ['E-commerce', 'CCPA', 'COPPA', 'Ads'],
    enTitle: 'E-commerce store with ads',
    enDescription: 'Online store: addresses, payments, advertising pixels. Covers GDPR, CCPA, CalOPPA, COPPA.',
  },
  {
    i18nKey: 'mobile',
    hash: encodePolicyToHash({
      businessName: 'Trailhead',
      websiteUrl: 'https://trailhead.example',
      businessType: 'mobile-app',
      jurisdiction: 'Brazil',
      dataCollected: ['emails', 'user-accounts', 'usage-data', 'analytics', 'device-info', 'location-data'],
      serviceIds: ['mixpanel', 'sendgrid', 'aws'],
      lawIds: ['gdpr', 'ccpa', 'caloppa', 'lgpd'],
      contactEmail: 'privacy@trailhead.example',
      hasDpo: false,
      tone: 'professional',
    }),
    tags: ['Mobile', 'LGPD', 'GDPR'],
    enTitle: 'Mobile app with analytics',
    enDescription: 'iOS/Android app: accounts, usage data, push notifications. Covers GDPR, CCPA, CalOPPA, LGPD.',
  },
];
---
<Layout
  title="Example privacy policies — PrivacyPolGen"
  description="See real privacy policies generated by PrivacyPolGen for different business types: blogs, SaaS, e-commerce, and mobile apps."
>
  <section class="border-b border-border bg-bg-elevated/30">
    <div class="mx-auto max-w-6xl px-6 py-10">
      <p class="text-sm text-fg-muted" data-i18n="examplesPage.breadcrumb">Examples</p>
      <h1 class="text-3xl md:text-4xl font-semibold tracking-tight" data-i18n="examplesPage.heading">See real policies generated by PrivacyPolGen.</h1>
      <p class="mt-2 text-fg-muted max-w-2xl" data-i18n="examplesPage.subtext">Click any example to open the full policy. Each one is generated entirely client-side from the answers encoded in the URL.</p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-12">
    <div class="grid gap-4 md:grid-cols-2">
      {samples.map((s) => (
        <a
          href={`/p?h=${s.hash}`}
          class="group rounded-card border border-border bg-bg-elevated p-6 hover:border-fg-muted transition-colors"
        >
          <div class="flex flex-wrap gap-1.5 mb-3">
            {s.tags.map((tag) => (
              <span class="rounded-full bg-bg-card border border-border px-2 py-0.5 text-[10px] uppercase tracking-wider text-fg-muted">{tag}</span>
            ))}
          </div>
          <h3 class="text-lg font-semibold tracking-tight group-hover:underline underline-offset-2" data-i18n={`examplesPage.samples.${s.i18nKey}.title`}>{s.enTitle}</h3>
          <p class="text-sm text-fg-muted mt-2 leading-relaxed" data-i18n={`examplesPage.samples.${s.i18nKey}.description`}>{s.enDescription}</p>
          <div class="mt-4 inline-flex items-center gap-1 text-xs text-fg-muted group-hover:text-fg">
            <span data-i18n="examplesPage.openPolicy">Open policy</span>
            <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-12 text-center">
      <p class="text-fg-muted text-sm" data-i18n="examplesPage.ctaLabel">Want a custom one?</p>
      <a
        href="/generate"
        class="mt-4 inline-flex h-10 items-center rounded-button bg-fg text-bg px-5 text-sm font-medium hover:opacity-90"
        data-i18n="examplesPage.cta"
      >
        Generate your own →
      </a>
    </div>
  </section>
</Layout>

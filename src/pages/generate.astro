---
// src/pages/generate.astro
// Hub page — choose which legal document to generate.
import Layout from '@/layouts/Layout.astro';
import BreadcrumbList from '@/components/BreadcrumbList.astro';
import { getTranslations, t } from '@/lib/i18n-server';

const locale = 'en';
const tx = await getTranslations(locale);

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Generate', url: '/generate' },
];

const generatorKeys = ['pp', 'terms', 'cookie'] as const;
const generatorIcons = ['shield', 'file-text', 'cookie'] as const;
const generatorHrefs = ['/generate/privacy-policy', '/generate/terms', '/generate/cookie-policy'] as const;
---
<Layout
  title="Generate legal documents — PrivacyPolGen"
  description="Create free privacy policies, terms & conditions, and cookie policies for your website. No signup required."
  schemaType="BreadcrumbList"
  breadcrumbs={breadcrumbs}
>
  <BreadcrumbList items={breadcrumbs} />

  <!-- SoftwareApplication JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'PrivacyPolGen',
    description: 'Free privacy policy generator for websites, SaaS, e-commerce, and mobile apps. Generate GDPR, CCPA, COPPA, and DPDP compliant privacy policies in under 60 seconds. No signup needed.',
    url: 'https://www.privacypolgen.in/generate',
    applicationCategory: 'BusinessApplication',
    applicationSubCategory: 'Privacy Policy Generator',
    operatingSystem: 'Any',
    browserRequirements: 'Modern web browser (Chrome, Firefox, Safari, Edge)',
    softwareVersion: '1.0',
    image: 'https://www.privacypolgen.in/og.png',
    author: {
      '@type': 'Person',
      name: 'Reuben Richard Lancer',
      url: 'https://github.com/reuben-exec',
    },
    offers: [
      {
        '@type': 'Offer',
        name: 'Free',
        price: '0',
        priceCurrency: 'USD',
        description: 'Generate privacy policies with HTML, Markdown, and plain text export',
      },
    ],
    featureList: [
      'GDPR-compliant privacy policy generation',
      'CCPA/CPRA-compliant privacy policy generation',
      'COPPA-compliant privacy policy for children\'s apps',
      'DPDP-compliant privacy policy for India',
      'Multiple export formats (HTML, Markdown, plain text)',
      'Shareable policy links via URL hash',
      'i18n support in 17 languages',
      'No signup or server-side storage required',
    ],
    sameAs: [
      'https://github.com/reuben-exec/privacypolgen',
      'https://x.com/classic_bruv04',
    ],
    softwareHelp: {
      '@type': 'WebPage',
      url: 'https://www.privacypolgen.in/contact',
    },
    inLanguage: ['en', 'es', 'fr', 'de', 'hi', 'ja', 'zh', 'pt', 'ru', 'ar', 'bn', 'nl', 'ko', 'ta', 'tr', 'vi', 'ka'],
  })} />

  <section class="border-b border-border bg-bg-elevated/30">
    <div class="mx-auto max-w-6xl px-6 py-12 md:py-16">
      <p class="text-sm text-fg-muted">{t(tx, 'generateHub.breadcrumb')}</p>
      <h1 class="text-3xl md:text-4xl font-semibold tracking-tight mt-1">{t(tx, 'generateHub.heading')}</h1>
      <p class="mt-2 text-fg-muted max-w-2xl">{t(tx, 'generateHub.subtext')}</p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-12">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {generatorKeys.map((key, idx) => (
        <a
          href={generatorHrefs[idx]}
          class="group rounded-card border border-border bg-bg-elevated p-6 transition-all hover:border-fg-muted/30 hover:shadow-sm hover:-translate-y-0.5"
        >
          <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-fg/5 text-fg group-hover:bg-fg/10 transition-colors">
            {generatorIcons[idx] === 'shield' && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-5 w-5">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
              </svg>
            )}
            {generatorIcons[idx] === 'file-text' && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-5 w-5">
                <path d="M14 3v4a1 1 0 0 0 1 1h4" />
                <path d="M17 21H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7l5 5v11a2 2 0 0 1-2 2z" />
                <line x1="9" y1="9" x2="10" y2="9" />
                <line x1="9" y1="13" x2="15" y2="13" />
                <line x1="9" y1="17" x2="15" y2="17" />
              </svg>
            )}
            {generatorIcons[idx] === 'cookie' && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
                <path d="M12 2a10 10 0 1 0 10 10 4 4 0 0 1-5-5 4 4 0 0 1-5-5" />
                <path d="M8.5 8.5v.01" />
                <path d="M16 15.5v.01" />
                <path d="M12 12v.01" />
                <path d="M11 17v.01" />
                <path d="M7 14v.01" />
              </svg>
            )}

          </div>
          <h3 class="text-base font-semibold tracking-tight text-fg">{t(tx, `generateHub.card.${key}.title`)}</h3>
          <p class="mt-1.5 text-sm text-fg-muted leading-relaxed">{t(tx, `generateHub.card.${key}.desc`)}</p>
          <div class="mt-4 inline-flex items-center gap-1.5 text-xs font-medium text-fg opacity-0 group-hover:opacity-100 transition-opacity">
            Generate
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-3.5 w-3.5">
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>

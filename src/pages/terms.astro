---
// src/pages/terms.astro
import Layout from '@/layouts/Layout.astro';
import BreadcrumbList from '@/components/BreadcrumbList.astro';
import { getTranslations, t } from '@/lib/i18n-server';

const locale = 'en';
const tx = await getTranslations(locale);

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Terms of Service', url: '/terms' },
];
---

<Layout
  title="Terms of Service — PrivacyPolGen"
  description="PrivacyPolGen Terms of Service — terms governing the use of our free privacy policy generator."
  schemaType="BreadcrumbList"
  breadcrumbs={breadcrumbs}
>
  <BreadcrumbList items={breadcrumbs} />
  <section class="border-b border-border bg-bg-elevated/30">
    <div class="mx-auto max-w-3xl px-6 py-10">
      <p class="text-sm text-fg-muted">{t(tx, 'termsPage.breadcrumb')}</p>
      <h1 class="text-3xl md:text-4xl font-semibold tracking-tight">{t(tx, 'termsPage.heading')}</h1>
      <p class="mt-2 text-fg-muted text-sm">{t(tx, 'termsPage.lastUpdated')}</p>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-6 py-12">
    <div class="prose prose-sm max-w-none text-fg-muted space-y-6 [&_h2]:text-lg [&_h2]:font-semibold [&_h2]:tracking-tight [&_h2]:text-fg [&_h2]:mt-10 [&_h2]:mb-3 [&_h3]:text-base [&_h3]:font-semibold [&_h3]:text-fg [&_h3]:mt-8 [&_h3]:mb-2 [&_p]:leading-relaxed [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:space-y-1.5 [&_li]:leading-relaxed [&_strong]:text-fg">

      <h2>{t(tx, 'termsPage.sections.intro.title')}</h2>
      <p>{t(tx, 'termsPage.sections.intro.body')}</p>

      <h2>{t(tx, 'termsPage.sections.description.title')}</h2>
      <p>{t(tx, 'termsPage.sections.description.body')}</p>

      <h2>{t(tx, 'termsPage.sections.notLegalAdvice.title')}</h2>
      <p>{t(tx, 'termsPage.sections.notLegalAdvice.body')}</p>

      <h2>{t(tx, 'termsPage.sections.noWarranties.title')}</h2>
      <p>{t(tx, 'termsPage.sections.noWarranties.body')}</p>

      <h2>{t(tx, 'termsPage.sections.limitationLiability.title')}</h2>
      <p>{t(tx, 'termsPage.sections.limitationLiability.body')}</p>

      <h2>{t(tx, 'termsPage.sections.indemnification.title')}</h2>
      <p>{t(tx, 'termsPage.sections.indemnification.body')}</p>

      <h2>{t(tx, 'termsPage.sections.intellectualProperty.title')}</h2>
      <p>{t(tx, 'termsPage.sections.intellectualProperty.body')}</p>

      <h2>{t(tx, 'termsPage.sections.thirdParty.title')}</h2>
      <p>{t(tx, 'termsPage.sections.thirdParty.body')}</p>

      <h2>{t(tx, 'termsPage.sections.changes.title')}</h2>
      <p>{t(tx, 'termsPage.sections.changes.body')}</p>

      <h2>{t(tx, 'termsPage.sections.governingLaw.title')}</h2>
      <p>{t(tx, 'termsPage.sections.governingLaw.body')}</p>

      <h2>{t(tx, 'termsPage.sections.contact.title')}</h2>
      <p>{t(tx, 'termsPage.sections.contact.body')}</p>

    </div>
  </section>
</Layout>
---
// src/pages/blog/[...slug].astro
import Layout from '@/layouts/Layout.astro';
import BreadcrumbList from '@/components/BreadcrumbList.astro';
import { getCollection, render } from 'astro:content';
import { getTranslations, t } from '@/lib/i18n-server';
import AdUnit from '@/components/AdUnit.astro';

const locale = 'en';
const tx = await getTranslations(locale);

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const breadcrumbs = [
  { name: t(tx, 'home'), url: '/' },
  { name: t(tx, 'blog'), url: '/blog' },
  { name: post.data.title, url: `/blog/${post.id}` },
];
---

<Layout
  title={`${post.data.title} — PrivacyPolGen Blog`}
  description={post.data.description}
  schemaType="Article"
  ogType="article"
  breadcrumbs={breadcrumbs}
  article={{
    publishedTime: post.data.pubDate.toISOString(),
    modifiedTime: post.data.updatedDate?.toISOString(),
    author: post.data.author,
    section: post.data.tags[0] || 'privacy',
    tags: post.data.tags,
  }}
>
  <BreadcrumbList items={breadcrumbs} />

  <article class="mx-auto max-w-3xl px-6 py-12">
    <header class="mb-8">
      <div class="flex flex-wrap gap-1.5 mb-4">
        {post.data.tags.map((tag) => (
          <span class="rounded-full bg-bg-card border border-border px-2 py-0.5 text-[10px] uppercase tracking-wider text-fg-muted">{tag}</span>
        ))}
      </div>
      <h1 class="text-3xl md:text-4xl font-semibold tracking-tight">{post.data.title}</h1>
      <div class="mt-3 flex items-center gap-3 text-sm text-fg-muted">
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        {post.data.updatedDate && (
          <>
            <span>·</span>
            <span>
              {t(tx, 'blogPost.updated')}{' '}
              {post.data.updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </span>
          </>
        )}
        <span>·</span>
        <span>{post.data.author}</span>
      </div>
    </header>

    <div class="prose prose-sm max-w-none text-fg-muted space-y-6 [&_h2]:text-lg [&_h2]:font-semibold [&_h2]:tracking-tight [&_h2]:text-fg [&_h2]:mt-10 [&_h2]:mb-3 [&_h3]:text-base [&_h3]:font-semibold [&_h3]:text-fg [&_h3]:mt-8 [&_h3]:mb-2 [&_p]:leading-relaxed [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:space-y-1.5 [&_ol]:list-decimal [&_ol]:pl-5 [&_ol]:space-y-1.5 [&_li]:leading-relaxed [&_strong]:text-fg [&_a]:underline [&_a]:underline-offset-2 [&_a]:hover:text-fg [&_code]:bg-bg-elevated [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded [&_code]:text-sm [&_pre]:bg-bg-elevated [&_pre]:p-4 [&_pre]:rounded-lg [&_pre]:overflow-x-auto [&_table]:w-full [&_table]:border-collapse [&_th]:text-left [&_th]:font-semibold [&_th]:text-fg [&_th]:border-b [&_th]:border-border [&_th]:p-2 [&_td]:border-b [&_td]:border-border [&_td]:p-2 [&_blockquote]:border-l-4 [&_blockquote]:border-border [&_blockquote]:pl-4 [&_blockquote]:italic">
      <Content />
    </div>

    <AdUnit slot="XXXXXXXXXX" />

    <footer class="mt-12 pt-8 border-t border-border">
      <a
        href="/blog"
        class="inline-flex items-center gap-1 text-sm text-fg-muted hover:text-fg transition-colors"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        {t(tx, 'blogPost.backToBlog')}
      </a>
    </footer>
  </article>
</Layout>

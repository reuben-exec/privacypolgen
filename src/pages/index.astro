---
// src/pages/index.astro
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/sections/Hero.astro';
import TrustBar from '@/components/sections/TrustBar.astro';
import FeatureGrid from '@/components/sections/FeatureGrid.astro';
import HowItWorks from '@/components/sections/HowItWorks.astro';
import Comparison from '@/components/sections/Comparison.astro';
import Pricing from '@/components/sections/Pricing.astro';
import FAQ from '@/components/sections/FAQ.astro';
---
<Layout
  title="PrivacyPolGen — Free privacy policy generator (GDPR, CCPA, COPPA)"
  description="Generate a complete, lawyer-grade privacy policy for your website, SaaS, e-commerce, or mobile app in under 60 seconds. Free, no signup, no data sent to a server."
>
  <Hero />
  <TrustBar />

  <!-- Why You Need a Privacy Policy — SEO content -->
  <section class="border-t border-border">
    <div class="mx-auto max-w-3xl px-6 py-16">
      <h2 class="text-2xl font-semibold tracking-tight mb-4" data-i18n="homeIntro.heading">Why you need a privacy policy</h2>
      <p class="text-fg-muted leading-relaxed" data-i18n="homeIntro.body">
        Every website, SaaS app, or e-commerce store that collects personal data needs a privacy policy. It's required by law under GDPR, CCPA, and dozens of other regulations worldwide. But hiring a lawyer costs $500+ per draft, and generic templates don't account for your specific business practices — the services you use, the data you collect, and the jurisdictions you operate in.
      </p>
      <p class="text-fg-muted leading-relaxed mt-4" data-i18n="homeIntro.body2">
        PrivacyPolGen solves this. Our intelligent wizard asks you 5 targeted questions about your business, walks you through the data you collect and the third-party services you integrate, then generates a complete, customized privacy policy in under 60 seconds. All of it happens in your browser — nothing is sent to a server.
      </p>
    </div>
  </section>

  <FeatureGrid />
  <HowItWorks />
  <Comparison />
  <Pricing />
  <FAQ schemaType="FAQPage" />
  <section class="border-t border-border">
    <div class="mx-auto max-w-3xl px-6 py-20 text-center">
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight" data-i18n="homeCta.heading">Ready to ship your privacy policy?</h2>
      <p class="mt-3 text-fg-muted" data-i18n="homeCta.subtext">Generate yours in under a minute. Free, forever.</p>
      <a
        href="/generate"
        class="mt-8 inline-flex h-11 items-center rounded-button bg-fg text-bg font-medium px-6 hover:opacity-90"
        data-i18n="homeCta.cta"
      >
        Generate your policy →
      </a>
    </div>
  </section>
</Layout>

---
// src/pages/about.astro
import Layout from '@/layouts/Layout.astro';
import BreadcrumbList from '@/components/BreadcrumbList.astro';
import { getTranslations, t } from '@/lib/i18n-server';

const locale = 'en';
const tx = await getTranslations(locale);

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'About', url: '/about' },
];
---

<Layout
  title="About — PrivacyPolGen"
  description="PrivacyPolGen is a free privacy policy generator for indie developers, SaaS founders, and small businesses. No signup, no server, no catch."
  schemaType="BreadcrumbList"
  breadcrumbs={breadcrumbs}
>
  <BreadcrumbList items={breadcrumbs} />
  <!-- Hero -->
  <section class="border-b border-border bg-bg-elevated/30">
    <div class="mx-auto max-w-3xl px-6 py-10">
      <p class="text-sm text-fg-muted">{t(tx, 'aboutPage.breadcrumb')}</p>
      <h1 class="text-3xl md:text-4xl font-semibold tracking-tight">{t(tx, 'aboutPage.heading')}</h1>
      <p class="mt-2 text-fg-muted max-w-2xl">{t(tx, 'aboutPage.subtext')}</p>
    </div>
  </section>

  <!-- Mission -->
  <section class="mx-auto max-w-3xl px-6 py-16">
    <h2 class="text-2xl font-semibold tracking-tight mb-4">{t(tx, 'aboutPage.mission.heading')}</h2>
    <p class="text-fg-muted leading-relaxed">
      {t(tx, 'aboutPage.mission.body')}
    </p>
    <p class="text-fg-muted leading-relaxed mt-4">
      {t(tx, 'aboutPage.mission.body2')}
    </p>
  </section>

  <!-- How It Works -->
  <section class="border-t border-border bg-bg-elevated/30">
    <div class="mx-auto max-w-3xl px-6 py-16">
      <h2 class="text-2xl font-semibold tracking-tight mb-8 text-center">{t(tx, 'aboutPage.howItWorks.heading')}</h2>
      <div class="grid gap-6 md:grid-cols-3">
        <div class="rounded-card border border-border bg-bg p-6 text-center">
          <div class="flex h-10 w-10 items-center justify-center rounded-full bg-fg/10 mx-auto mb-4">
            <span class="text-sm font-bold">1</span>
          </div>
          <h3 class="font-semibold mb-2">{t(tx, 'aboutPage.howItWorks.step1.title')}</h3>
          <p class="text-sm text-fg-muted">{t(tx, 'aboutPage.howItWorks.step1.body')}</p>
        </div>
        <div class="rounded-card border border-border bg-bg p-6 text-center">
          <div class="flex h-10 w-10 items-center justify-center rounded-full bg-fg/10 mx-auto mb-4">
            <span class="text-sm font-bold">2</span>
          </div>
          <h3 class="font-semibold mb-2">{t(tx, 'aboutPage.howItWorks.step2.title')}</h3>
          <p class="text-sm text-fg-muted">{t(tx, 'aboutPage.howItWorks.step2.body')}</p>
        </div>
        <div class="rounded-card border border-border bg-bg p-6 text-center">
          <div class="flex h-10 w-10 items-center justify-center rounded-full bg-fg/10 mx-auto mb-4">
            <span class="text-sm font-bold">3</span>
          </div>
          <h3 class="font-semibold mb-2">{t(tx, 'aboutPage.howItWorks.step3.title')}</h3>
          <p class="text-sm text-fg-muted">{t(tx, 'aboutPage.howItWorks.step3.body')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why It's Free -->
  <section class="mx-auto max-w-3xl px-6 py-16">
    <h2 class="text-2xl font-semibold tracking-tight mb-4">{t(tx, 'aboutPage.whyFree.heading')}</h2>
    <p class="text-fg-muted leading-relaxed">
      {t(tx, 'aboutPage.whyFree.body')}
    </p>
  </section>

  <!-- CTA -->
  <section class="border-t border-border bg-bg-elevated/30">
    <div class="mx-auto max-w-3xl px-6 py-16 text-center">
      <h2 class="text-2xl font-semibold tracking-tight mb-4">{t(tx, 'aboutPage.cta.heading')}</h2>
      <p class="text-fg-muted mb-6">{t(tx, 'aboutPage.cta.subtext')}</p>
      <a href="/generate" class="inline-flex h-10 items-center rounded-button bg-fg text-bg text-sm font-medium px-5 transition-opacity hover:opacity-90">{t(tx, 'aboutPage.cta.button')}</a>
    </div>
  </section>

  <!-- Feedback CTA -->
  <section class="border-t border-border bg-bg-elevated/30">
    <div class="mx-auto max-w-4xl px-6 py-20">
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-center mb-10">Help shape this project</h2>
      <div class="grid gap-6 md:grid-cols-2">
        <div class="rounded-card border border-border bg-bg p-8 text-center">
          <div class="flex h-12 w-12 items-center justify-center rounded-full bg-fg/10 mx-auto mb-4">
            <svg class="h-6 w-6 text-fg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold tracking-tight mb-2">Request a Feature</h3>
          <p class="text-sm text-fg-muted mb-6">Got an idea that would make this tool better? Let me know.</p>
          <a href="mailto:benatwork4747@gmail.com?subject=Feature%20Request" class="inline-flex h-10 items-center rounded-button bg-fg text-bg text-sm font-medium px-5 transition-opacity hover:opacity-90">Send Feature Request →</a>
        </div>
        <div class="rounded-card border border-border bg-bg p-8 text-center">
          <div class="flex h-12 w-12 items-center justify-center rounded-full bg-fg/10 mx-auto mb-4">
            <svg class="h-6 w-6 text-fg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
              <line x1="12" y1="9" x2="12" y2="13"/>
              <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold tracking-tight mb-2">Report a Bug</h3>
          <p class="text-sm text-fg-muted mb-6">Something not working right? Help me fix it.</p>
          <a href="mailto:benatwork4747@gmail.com?subject=Bug%20Report" class="inline-flex h-10 items-center rounded-button bg-fg text-bg text-sm font-medium px-5 transition-opacity hover:opacity-90">Report a Bug →</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

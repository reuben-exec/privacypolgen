---
// src/pages/generate/cookie-policy.astro
import Layout from '@/layouts/Layout.astro';
import CookieWizard from '@/components/CookieWizard';
import BreadcrumbList from '@/components/BreadcrumbList.astro';
import { getTranslations, t } from '@/lib/i18n-server';
import AdUnit from '@/components/AdUnit.astro';

const locale = 'en';
const tx = await getTranslations(locale);

const breadcrumbs = [
  { name: t(tx, 'home'), url: '/' },
  { name: t(tx, 'generate'), url: '/generate' },
  { name: t(tx, 'cookieGeneratorPage.breadcrumb'), url: '/generate/cookie-policy' },
];
---
<Layout
  title={t(tx, 'cookieGeneratorPage.title')}
  description={t(tx, 'cookieGeneratorPage.description')}
  schemaType="BreadcrumbList"
  breadcrumbs={breadcrumbs}
>
  <BreadcrumbList items={breadcrumbs} />
  <section class="border-b border-border bg-bg-elevated/30">
    <div class="mx-auto max-w-6xl px-6 py-10">
      <p class="text-sm text-fg-muted">{t(tx, 'cookieGeneratorPage.breadcrumb')}</p>
      <h1 class="text-3xl md:text-4xl font-semibold tracking-tight">{t(tx, 'cookieGeneratorPage.heading')}</h1>
      <p class="mt-2 text-fg-muted max-w-2xl">{t(tx, 'cookieGeneratorPage.subtext')}</p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-12">
    <CookieWizard client:load />
  </section>

  <AdUnit slot="XXXXXXXXXX" />
</Layout>

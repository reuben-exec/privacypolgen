---
// src/pages/generate/cookie-banner.astro
// Cookie consent banner code generator — premium feature.
import Layout from '@/layouts/Layout.astro';
import { CookieBannerGenerator } from '@/components/CookieBannerGenerator';

const title = 'Free Cookie Consent Banner Generator — PrivacyPolGen';
const description = 'Generate a free, customizable cookie consent banner for your website. GDPR-ready with category toggles, script blocking, and localStorage persistence.';
---

<Layout title={title} description={description}>
  <div class="mx-auto max-w-5xl space-y-8 py-12 px-4">
    <div class="space-y-3">
      <div class="flex items-center gap-2">
        <span class="inline-flex h-7 items-center gap-1 rounded-full bg-accent/10 px-3 text-xs font-semibold text-accent">Premium</span>
        <a href="/generate/" class="text-xs text-fg-muted hover:text-fg transition-colors">← Back to Generators</a>
      </div>
      <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">
        Cookie Consent Banner Generator
      </h1>
      <p class="text-fg-muted text-sm max-w-xl">
        Generate a ready-to-paste cookie consent banner for your website. Customize position, colors, and cookie categories. Includes script blocking, localStorage persistence, and GDPR-compliant consent management.
      </p>
    </div>

    <CookieBannerGenerator client:load />

    {/* FAQ */}
    <div class="space-y-6 rounded-card border border-border bg-bg-elevated p-6">
      <h2 class="text-lg font-semibold tracking-tight">Frequently Asked Questions</h2>
      <div class="space-y-4 text-sm text-fg-muted">
        <div>
          <h3 class="font-medium text-fg mb-1">What does this banner do?</h3>
          <p>It displays a consent notice when a visitor first arrives. Visitors can toggle which cookie categories they allow (Analytics, Preference, Marketing). Essential cookies are always on. The banner stores preferences in localStorage and reappears after the configured expiry.</p>
        </div>
        <div>
          <h3 class="font-medium text-fg mb-1">Is it GDPR compliant?</h3>
          <p>The banner provides granular category control, allows rejecting all non-essential cookies, links to your privacy and cookie policies, and persists consent with a configurable expiry. However, actual compliance depends on your overall site practices — this tool generates the banner UI, not legal advice.</p>
        </div>
        <div>
          <h3 class="font-medium text-fg mb-1">How do I use it?</h3>
          <p>Copy the generated HTML snippet and paste it before the closing <code>{'</body>'}</code> tag of your website. The banner will automatically appear for first-time visitors and save their preferences.</p>
        </div>
        <div>
          <h3 class="font-medium text-fg mb-1">Can I listen for consent changes?</h3>
          <p>Yes. The banner dispatches a <code>ppg:cookies</code> custom event on <code>window</code> with a <code>detail</code> object containing boolean flags for each category: <code>{'{ essential, analytics, preference, marketing }'}</code>. Use this to conditionally load analytics scripts, marketing pixels, etc.</p>
        </div>
      </div>
    </div>
  </div>
</Layout>

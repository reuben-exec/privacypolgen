---
import Layout from '@/layouts/Layout.astro';
import { getTranslations, t } from '@/lib/i18n-server';

const locale = 'en';
const tx = await getTranslations(locale);
---
<Layout title={t(tx, 'serverError.title')} description={t(tx, 'serverError.description')} pageKey="500">
  <section class="flex flex-col items-center justify-center py-32 text-center">
    <h1 class="text-6xl font-bold">500</h1>
    <p class="mt-4 text-xl text-fg-muted">{t(tx, 'serverError.heading')}</p>
    <p class="mt-2 text-fg-muted">{t(tx, 'serverError.subtext')}</p>
    <a href="/" class="btn-primary mt-8">{t(tx, 'serverError.backHome')}</a>
  </section>
</Layout>

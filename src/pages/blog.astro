---
import Layout from '@/layouts/Layout.astro';
import BreadcrumbList from '@/components/BreadcrumbList.astro';
import AdUnit from '@/components/AdUnit.astro';
import { getCollection } from 'astro:content';
import { getTranslations, t } from '@/lib/i18n-server';

const locale = 'en';
const tx = await getTranslations(locale);

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Blog', url: '/blog' },
];

// Fetch all published posts, sorted by pubDate descending
const posts = await getCollection('blog', ({ data }) => !data.draft);
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const featuredPost = posts.find(p => p.id === 'gdpr-privacy-policy-template');
const featuredDate = featuredPost?.data.pubDate ?? new Date('2024-01-15T10:00:00.000Z');

// All other posts (excluding the featured one)
const otherPosts = posts.filter(p => p.id !== 'gdpr-privacy-policy-template');
---

<Layout
  title="Privacy Policy Blog | PrivacyPolGen"
  description="Expert insights, guides, and compliance strategies for privacy policies. Stay updated with the latest in data protection and legal requirements."
  pageKey="blog"
  schemaType="WebPage"
  breadcrumbs={breadcrumbs}
>
  <BreadcrumbList items={breadcrumbs} />

  <section class="border-b border-border bg-bg-elevated/30">
    <div class="mx-auto max-w-3xl px-6 py-10">
      <p class="text-sm text-fg-muted">{t(tx, 'blogPage.breadcrumb')}</p>
      <h1 class="text-3xl md:text-4xl font-semibold tracking-tight">{t(tx, 'blogPage.heading')}</h1>
      <p class="mt-2 text-fg-muted max-w-2xl">
        {t(tx, 'blogPage.subtext')}
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-6 py-12">
    <article class="group rounded-card border-2 border-border bg-bg p-10 hover:shadow-lg transition-shadow">
      <div class="mb-6">
        <div class="flex items-center gap-4 mb-4">
          <time class="text-sm text-fg-muted">
            {featuredDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
          <span class="text-xs px-3 py-1 rounded-full bg-bg-elevated text-fg-muted border border-border">{t(tx, 'blogPage.featuredArticle.tag')}</span>
        </div>
        <h2 class="text-3xl font-semibold mb-6 group-hover:text-fg transition-colors">
          <a href="/blog/gdpr-privacy-policy-template">{t(tx, 'blogPage.featuredArticle.title')}</a>
        </h2>
        <p class="text-fg-muted mb-8 text-lg">
          {t(tx, 'blogPage.featuredArticle.description')}
        </p>
        <a
          href="/blog/gdpr-privacy-policy-template"
          class="inline-flex items-center gap-2.5 px-6 py-2.5 rounded-button bg-fg text-bg font-medium hover:opacity-90 transition-opacity group text-sm"
        >
          <span>{t(tx, 'blogPage.featuredArticle.readMore')}</span>
          <svg
            class="w-4 h-4 transform transition-transform duration-200 group-hover:translate-x-1"
            fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
          >
            <path d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </article>
  </section>

  <AdUnit slot="XXXXXXXXXX" />

  {otherPosts.length > 0 && (
    <section class="mx-auto max-w-5xl px-6 py-8 mb-8">
      <h2 class="text-2xl font-semibold mb-2">{t(tx, 'blogPage.allPosts.heading')}</h2>
      <p class="text-fg-muted mb-10 max-w-3xl">{t(tx, 'blogPage.allPosts.text')}</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {otherPosts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="group rounded-card border border-border bg-bg p-6 transition-all hover:border-fg-muted/30 hover:shadow-sm hover:-translate-y-0.5"
          >
            <div class="flex flex-wrap gap-1.5 mb-3">
              {post.data.tags.map((tag) => (
                <span class="rounded-full bg-bg-card border border-border px-2 py-0.5 text-[10px] uppercase tracking-wider text-fg-muted">{tag}</span>
              ))}
            </div>
            <h3 class="text-base font-semibold tracking-tight text-fg group-hover:text-fg transition-colors mb-2">
              {post.data.title}
            </h3>
            <p class="text-sm text-fg-muted leading-relaxed mb-4 line-clamp-3">
              {post.data.description}
            </p>
            <div class="flex items-center gap-2 text-xs text-fg-muted">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </time>
              <span>·</span>
              <span class="inline-flex items-center gap-1 text-fg-muted group-hover:text-fg transition-colors">
                Read more
                <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="mx-auto max-w-3xl px-6 mb-20">
    <div class="rounded-card border border-border bg-bg-elevated p-16 text-center">
      <h2 class="text-3xl font-semibold mb-4">{t(tx, 'blogPage.cta.heading')}</h2>
      <p class="text-fg-muted mb-10 max-w-2xl mx-auto text-lg">
        {t(tx, 'blogPage.cta.subtext')}
      </p>
      <div class="flex flex-col sm:flex-row gap-6 justify-center">
        <a
          href="/generate"
          class="px-10 py-4 rounded-button bg-fg text-bg font-medium text-lg hover:opacity-90"
        >
          <span>{t(tx, 'blogPage.cta.generate')}</span>
        </a>
        <a
          href="/contact"
          class="px-10 py-4 rounded-button border border-border hover:bg-bg-elevated text-lg"
        >
          <span>{t(tx, 'blogPage.cta.contact')}</span>
        </a>
      </div>
    </div>
  </section>
</Layout>

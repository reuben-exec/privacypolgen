---
// src/pages/pricing.astro
import Layout from '@/layouts/Layout.astro';
import Pricing from '@/components/sections/Pricing.astro';
import FAQ from '@/components/sections/FAQ.astro';
---
<Layout
  title="Pricing — PrivacyPolGen"
  description="PrivacyPolGen is free forever. Premium adds PDF/DOCX export, custom branding, and hosted policy pages."
>
  <section class="border-b border-border bg-bg-elevated/30">
    <div class="mx-auto max-w-6xl px-6 py-10">
      <p class="text-xs uppercase tracking-widest text-fg-faint mb-2" data-i18n="pricingPage.breadcrumb">Pricing</p>
      <h1 class="text-3xl md:text-4xl font-semibold tracking-tight" data-i18n="pricingPage.heading">Simple, fair pricing.</h1>
      <p class="mt-2 text-fg-muted max-w-2xl" data-i18n="pricingPage.subtext">The core generator is free for everyone. Premium is for teams that need polished exports and integrations.</p>
    </div>
  </section>
  <Pricing />
  <FAQ schemaType="FAQPage" />
</Layout>

  <!-- Hero -->
  <section class="border-b border-border bg-bg-elevated/30">
    <div class="mx-auto max-w-3xl px-6 pt-20 pb-10">
      <p class="text-sm text-fg-muted">{t(tx, 'reviewPage.breadcrumb')}</p>
      <h1 class="text-3xl md:text-4xl font-semibold tracking-tight">{t(tx, 'reviewPage.heading')}</h1>
      <p class="mt-2 text-fg-faint max-w-2xl">{t(tx, 'reviewPage.subtext')}</p>
    </div>
  </section>

  <!-- Review Form -->
  <section class="mx-auto max-w-3xl px-6 py-16">
    <!-- Success state (shown after successful submission) -->
    <div id="success-message" class="hidden rounded-card border border-border bg-bg-elevated p-8 text-center">
      <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-fg/10">
        <svg class="h-8 w-8 text-fg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
          <polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
      </div>
      <h2 class="text-2xl font-semibold tracking-tight mb-2">{t(tx, 'reviewPage.successTitle')}</h2>
      <p class="text-fg-muted max-w-md mx-auto">{t(tx, 'reviewPage.successBody')}</p>
      <a
        href="/review"
        class="mt-6 inline-flex h-10 items-center rounded-button bg-fg text-bg text-sm font-medium px-5 transition-opacity hover:opacity-90"
      >{t(tx, 'reviewPage.successLink')}</a>
    </div>

    <!-- Error state -->
    <div id="error-message" class="hidden mb-8 rounded-card border border-red-500/30 bg-red-500/10 p-4 text-sm text-red-600 dark:text-red-400">
      <div class="flex items-start gap-3">
        <svg class="mt-0.5 h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">

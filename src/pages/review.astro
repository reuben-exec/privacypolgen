<style>
  /* ── Star Rating ────────────────────────────────────────────── */
  .star-rating input {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  .star-rating label {
    cursor: pointer;
    transition: transform 0.15s ease;
    color: var(--color-fg-muted);
  }

  .star-rating label:hover,
  .star-rating label:hover ~ label,
  .star-rating input:checked ~ label {
    color: #f59e0b; /* amber-500 */
  }

  .star-rating label:hover {
    transform: scale(1.15);
  }

  .star-rating input:checked + label {
    transform: scale(1);
  }

  .star-rating input:focus-visible + label {
    outline: 2px solid var(--color-fg);
    outline-offset: 3px;
    border-radius: 4px;
  }

  .star-rating .star-icon {
    transition: fill 0.15s ease, transform 0.15s ease;
  }

  .star-rating label:hover .star-icon,
  .star-rating label:hover ~ label .star-icon,
  .star-rating input:checked ~ label .star-icon {
    fill: #f59e0b;
  }

  /* ── Review Form ────────────────────────────────────────────── */
  .review-form .label {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-fg-muted);
  }

  .review-form .input {
    background-color: var(--color-bg);
    border-color: var(--color-border);
  }

  .review-form .input:focus {
    border-color: var(--color-fg-faint);
    background-color: var(--color-bg);
  }
</style>

<script is:inline define:vars={{ TURNSTILE_SITE_KEY }}>
  (function () {
    var form = document.getElementById('review-form-el');
    var formWrapper = document.getElementById('review-form');
    var successEl = document.getElementById('success-message');
    var errorEl = document.getElementById('error-message');
    var errorText = document.getElementById('error-text');
    var submitBtn = document.getElementById('review-submit');

    if (!form) return;

    form.addEventListener('submit', async function (e) {
      e.preventDefault();

      // Get Turnstile token
      var turnstileToken = '';
      var turnstileWidget = form.querySelector('.cf-turnstile');
      if (turnstileWidget && typeof turnstile !== 'undefined') {
        turnstileToken = turnstile.getResponse(turnstileWidget);
        if (!turnstileToken) {
          var hiddenInput = turnstileWidget.querySelector('[name="cf-turnstile-response"]');
          if (hiddenInput) turnstileToken = hiddenInput.value;
        }
      }
      if (!turnstileToken) {
        var directInput = form.querySelector('input[name="cf-turnstile-response"]');
        if (directInput) turnstileToken = directInput.value;
      }

      if (TURNSTILE_SITE_KEY && !turnstileToken) {
        errorEl.classList.remove('hidden');
        errorText.textContent = 'Please complete the CAPTCHA.';
        return;
      }

      // Get selected rating
      var ratingInput = form.querySelector('input[name="rating"]:checked');
      var rating = ratingInput ? ratingInput.value : null;

      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitting...';

      var data = {
        name: form.querySelector('#name').value,
        email: form.querySelector('#r-email').value,
        type: 'review',
        rating: rating,
        country: form.querySelector('#country').value,
        message: form.querySelector('#review').value,
        turnstileToken: turnstileToken,
      };

      try {
        var res = await fetch('/api/feedback', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        var result = await res.json();

        if (result.success) {
          formWrapper.classList.add('hidden');
          successEl.classList.remove('hidden');
          if (window.history.replaceState) {
            window.history.replaceState(null, '', window.location.pathname);
          }
        } else {
          errorEl.classList.remove('hidden');
          errorText.textContent = result.error || 'Something went wrong. Please try again or email me directly at benatwork4747@gmail.com.';
          submitBtn.disabled = false;
          submitBtn.textContent = 'Submit Review';
        }
      } catch {
        errorEl.classList.remove('hidden');
        errorText.textContent = 'Network error. Please try again.';
        submitBtn.disabled = false;
        submitBtn.textContent = 'Submit Review';
      }
    });
  })();
</script>

<!-- Load Turnstile if site key is present -->

        <span id="error-text">{t(tx, 'reviewPage.errorMessage')}</span>
      </div>
    </div>

    <!-- The form (hidden on success) -->
    <div id="review-form">
      <form
        id="review-form-el"
        class="review-form rounded-card border border-border bg-bg-elevated p-6 md:p-8 space-y-6"
      >
        <!-- Name -->
        <div>
          <label for="name" class="label">{t(tx, 'reviewPage.nameLabel')}</label>
          <input

---
// src/pages/review.astro
// Review page — users can leave feedback about PrivacyPolGen.
// Submissions are sent via Cloudflare Email Service to benatwork4747@gmail.com.
// No registration needed, completely free, unlimited submissions.
import Layout from '@/layouts/Layout.astro';
import BreadcrumbList from '@/components/BreadcrumbList.astro';
import { getTranslations, t } from '@/lib/i18n-server';

const tx = await getTranslations();
const TURNSTILE_SITE_KEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || '';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Review', url: '/review' },
];
---

<Layout
  title="Review — PrivacyPolGen"
  description="Leave a review for PrivacyPolGen. Your feedback helps me improve the free privacy policy generator for everyone."
  schemaType="BreadcrumbList"
  breadcrumbs={breadcrumbs}
>

---
// src/pages/privacy.astro
import Layout from '@/layouts/Layout.astro';
import BreadcrumbList from '@/components/BreadcrumbList.astro';
import { getTranslations, t } from '@/lib/i18n-server';

const locale = 'en';
const tx = await getTranslations(locale);

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Privacy Policy', url: '/privacy' },
];
---

<Layout
  title="Privacy Policy — PrivacyPolGen"
  description="PrivacyPolGen's own privacy policy — we collect no personal data. Everything runs client-side in your browser."
  schemaType="BreadcrumbList"
  breadcrumbs={breadcrumbs}
>
  <BreadcrumbList items={breadcrumbs} />
  <section class="border-b border-border bg-bg-elevated/30">
    <div class="mx-auto max-w-3xl px-6 py-10">
      <p class="text-sm text-fg-muted">{t(tx, 'privacyPage.breadcrumb')}</p>
      <h1 class="text-3xl md:text-4xl font-semibold tracking-tight">{t(tx, 'privacyPage.heading')}</h1>
      <p class="mt-2 text-fg-muted text-sm">{t(tx, 'privacyPage.lastUpdated')}</p>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-6 py-12">
    <div class="prose prose-sm max-w-none text-fg-muted space-y-6 [&_h2]:text-lg [&_h2]:font-semibold [&_h2]:tracking-tight [&_h2]:text-fg [&_h2]:mt-10 [&_h2]:mb-3 [&_h3]:text-base [&_h3]:font-semibold [&_h3]:text-fg [&_h3]:mt-8 [&_h3]:mb-2 [&_p]:leading-relaxed [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:space-y-1.5 [&_li]:leading-relaxed [&_strong]:text-fg">

      <h2>{t(tx, 'privacyPage.sections.intro.title')}</h2>
      <p>
        {t(tx, 'privacyPage.sections.intro.body')}
      </p>
      <p>
        {t(tx, 'privacyPage.sections.intro.body2')}
      </p>

      <h2>{t(tx, 'privacyPage.sections.noCollection.title')}</h2>
      <p>
        {t(tx, 'privacyPage.sections.noCollection.body')}
      </p>
      <ul>
        <li>{t(tx, 'privacyPage.sections.noCollection.list.0')}</li>
        <li>{t(tx, 'privacyPage.sections.noCollection.list.1')}</li>
        <li>{t(tx, 'privacyPage.sections.noCollection.list.2')}</li>
        <li>{t(tx, 'privacyPage.sections.noCollection.list.3')}</li>
        <li>{t(tx, 'privacyPage.sections.noCollection.list.4')}</li>
        <li>{t(tx, 'privacyPage.sections.noCollection.list.5')}</li>
      </ul>

      <h2>{t(tx, 'privacyPage.sections.technical.title')}</h2>
      <p>
        {t(tx, 'privacyPage.sections.technical.body')}
      </p>

      <h2>{t(tx, 'privacyPage.sections.localStorage.title')}</h2>
      <p>
        {t(tx, 'privacyPage.sections.localStorage.body')}
      </p>

      <h2>{t(tx, 'privacyPage.sections.thirdParty.title')}</h2>
      <p>
        {t(tx, 'privacyPage.sections.thirdParty.body')}
      </p>
      <ul>
        <li>{t(tx, 'privacyPage.sections.thirdParty.list.0')}</li>
        <li>{t(tx, 'privacyPage.sections.thirdParty.list.1')}</li>
      </ul>

      <h2>{t(tx, 'privacyPage.sections.dataRetention.title')}</h2>
      <p>
        {t(tx, 'privacyPage.sections.dataRetention.body')}
      </p>

      <h2>{t(tx, 'privacyPage.sections.yourRights.title')}</h2>
      <p>
        {t(tx, 'privacyPage.sections.yourRights.body')}
      </p>

      <h2>{t(tx, 'privacyPage.sections.changes.title')}</h2>
      <p>
        {t(tx, 'privacyPage.sections.changes.body')}
      </p>

      <h2>{t(tx, 'privacyPage.sections.contact.title')}</h2>
      <p>
        {t(tx, 'privacyPage.sections.contact.body')}
      </p>

    </div>
  </section>
</Layout>

---
// src/pages/p/index.astro
// Reads ?h=... from URL on the client and renders the decoded policy.
import Layout from '@/layouts/Layout.astro';
import { PolicyReader } from '@/components/PolicyReader';
---
<Layout
  title="Privacy Policy — PrivacyPolGen"
  description="View a privacy policy generated by PrivacyPolGen."
  noindex={true}
  bare={false}
>
  <section class="mx-auto max-w-4xl px-6 py-12">
    <PolicyReader client:only="react" />
  </section>
</Layout>

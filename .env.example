# Google AdSense publisher ID — leave empty in dev, set before deploying live
# Example: ca-pub-1234567890123456
PUBLIC_ADSENSE_CLIENT=

# LemonSqueezy checkout URL
# Get this from: LemonSqueezy Dashboard > Products > Copy Checkout Link
# Example: https://your-store.lemonsqueezy.com/checkout/buy/xxxxxxxx
PUBLIC_LEMONSQUEEZY_CHECKOUT_URL=

# Google Cloud Translation API key
# Required for PDF/DOCX export translation (non-English languages).
# Get one at: https://console.cloud.google.com/apis/credentials → Create API key
# Then enable: https://console.cloud.google.com/apis/library/translate.googleapis.com
# In production, set this as a Cloudflare Pages secret (not via .env).
# For local dev with the function: wrangler pages dev -- GOOGLE_TRANSLATE_API_KEY=xxx
GOOGLE_TRANSLATE_API_KEY=

# Google AdSense publisher ID — leave empty in dev, set before deploying live
# Example: ca-pub-1234567890123456
PUBLIC_ADSENSE_CLIENT=

# Google Analytics (GA4) Measurement ID — leave empty in dev, set before deploying live
# Get this from: Google Analytics Admin > Data Streams > Your Stream > Measurement ID
# Example: G-XXXXXXXX
PUBLIC_GA_ID=


# Cloudflare Turnstile site key (public, safe to expose)
# Get this from: Cloudflare Dashboard > Turnstile > Your Site > Site Key
# In production, set this as a Cloudflare Pages environment variable.
PUBLIC_TURNSTILE_SITE_KEY=

# Resend API key for sending feedback/review emails
# Get one free at: https://resend.com (100 emails/day free)
# In production, set this as a Cloudflare Pages secret: npx wrangler pages secret put RESEND_API_KEY
RESEND_API_KEY=
